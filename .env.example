# Server port (default: 2029)
PORT=2029

# Set to 'production' to enable trust proxy and stricter auth
NODE_ENV=development

# Password for authenticated resume API (`GET`/`PUT` `/api/resume`)
CLOUD_PASSWORD=

# Allow localhost to bypass auth in production (default: false)
TRUST_LOCALHOST_AUTH=false

# Optional: hostnames (comma-separated) that count as local dev, for /etc/hosts entries.
# Example line in /etc/hosts: 127.0.0.1 local.mccomb.ca
# LOCAL_DEV_HOSTS=local.mccomb.ca
