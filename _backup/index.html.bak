                    <div class="forecast-section-label">Portfolio Performance</div>
                    <div class="forecast-chart-wrap" id="forecast-chart-wrap">
                        <div class="forecast-chart-header">
                            <div>
                                <span class="forecast-chart-title">Manifold Profit</span>
                                <span class="forecast-chart-subtitle">@JeromeHPowell</span>
                            </div>
                            <div class="forecast-chart-stat" id="forecast-chart-stat">--</div>
                        </div>
                        <div class="forecast-chart-container">
                            <canvas id="forecast-chart" width="640" height="240"></canvas>
                            <div class="forecast-chart-tooltip" id="forecast-chart-tooltip"></div>
                        </div>
                        <div class="forecast-chart-range">
                            <span id="forecast-chart-start"></span>
                            <span id="forecast-chart-end"></span>
                        </div>
                    </div>

                    <div class="forecast-section-label">Featured Project</div>
                    <div class="forecast-card">
                        <h3>IL9CAST</h3>
