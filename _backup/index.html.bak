                        <h3>Manifold Markets</h3>
                        <p>@JeromeHPowell &mdash; #61 / 160,000 traders (top 0.04% volume). Top 0.5% in profit.</p>
                        <a href="https://manifold.markets/JeromeHPowell" target="_blank" class="tl-link">Profile &#8599;</a>
                    </div>
                    <div class="forecast-card">
                        <h3>Metaculus</h3>
                        <p>Calibrated forecaster.</p>
                        <a href="https://www.metaculus.com/accounts/profile/238376/" target="_blank" class="tl-link">Profile &#8599;</a>
                    </div>
                </div>
            `,
            hottakes: () => {
                return `<div class="page-hero">
                    <h1>Hot Takes</h1>
                    <p>Opinions I'm willing to defend. Spiciness rated 1&ndash;5.</p>
                </div>
                    <div class="filter-bar" id="expand-filter-bar"><button class="filter-pill active" data-cat="all">All</button></div>
                    <div class="takes-wall" id="expand-takes-wall">${renderTakesWall(allTakesData)}</div>`;
            },
            countdowns: () => {
                return `<div class="page-hero">
                    <h1>Countdowns</h1>
                    <p>Things I'm counting down to (and things that already happened).</p>
                </div>
                    <div class="countdown-grid" id="expand-countdown-grid">${renderCountdownCards(allCountdownsData)}</div>`;
            },
            blog: () => {
                return `<div class="blog-list" id="expand-blog-list">
                    <div class="page-hero">
                        <h1>Writing &amp; Ideas</h1>
                        <p>Thoughts on politics, data, prediction markets, and building things.</p>
                    </div>
                    <div class="blog-featured">
                        <div class="blog-featured-card" onclick="openExpandedArticle('peoples-edict')">
                            <img src="2500.webp" alt="People's Edict" class="blog-featured-image">
                            <div class="blog-featured-body">
                                <div class="blog-meta"><span class="blog-tag">Essay</span><span class="read-time">5 min read</span></div>
                                <h2>People's Edict</h2>
                                <p>An on-demand essay on power and strife, exploring when and how authority should be challenged.</p>
                                <span class="blog-read-link">Read essay &rarr;</span>
                            </div>
                        </div>
                    </div>
                    <div class="blog-grid">
                        <div class="blog-card" onclick="openExpandedArticle('median-voter-theory')">
                            <div class="blog-card-inner">
                                <div class="blog-meta"><span class="blog-tag">Politics</span><span>Jan 2025</span></div>
                                <h3>The Conflation Between Median Voter Theory and Trump's Win</h3>
                                <p>How the Trump Campaign Used an Obscure Political Science Concept to Move the Electorate</p>
                                <span class="blog-read-link">Read &rarr;</span>
                            </div>
                        </div>
                        <div class="blog-card" onclick="openExpandedArticle('nsa-surveillance')">
                            <div class="blog-card-inner">
                                <div class="blog-meta"><span class="blog-tag">Essay</span><span>Sep 2024</span></div>
                                <h3>Resolution on State Interception of Communications</h3>
                                <p>Why the intentional censorship and oversight of private communications without a warrant is unconstitutional</p>
                                <span class="blog-read-link">Read &rarr;</span>
                            </div>
                        </div>
                    </div>
                    <div id="expand-api-posts"></div>
                    <div class="blog-guestbook" id="expand-guestbook">
                        <div class="gb-header">
                            <h2>Guestbook</h2>
                            <p>Leave a message, say hi, or drop some feedback.</p>
                        </div>
                        <div class="gb-form" id="expand-gb-form">
                            <input type="text" name="name" placeholder="Your name" maxlength="40">
                            <textarea name="message" placeholder="Your message..." maxlength="200"></textarea>
                            <button class="gb-submit" onclick="signExpandedGuestbook()">Sign</button>
                        </div>
                        <div class="gb-status" id="expand-gb-status"></div>
                        <div class="gb-entries" id="expand-gb-entries"></div>
                    </div>
                </div>
                <div class="blog-article" id="expand-blog-article">
                    <a class="blog-back" onclick="closeExpandedArticle()">&larr; Back to all posts</a>
                    <div class="article-header" id="expand-article-header"></div>
                    <div class="article-body" id="expand-article-body"></div>
                </div>`;
            }
        };

        function expandCard(cardName) {
            currentExpandedCard = cardName;
            const overlay = document.getElementById('expand-overlay');
            const content = document.getElementById('expand-content');

            const generator = expandedContent[cardName];
            if (!generator) return;
            content.innerHTML = generator();
            overlay.style.display = 'block';
            requestAnimationFrame(() => overlay.classList.add('active'));
            overlay.scrollTop = 0;
            document.body.style.overflow = 'hidden';
            history.pushState({ card: cardName }, '', '#' + cardName);

            // Post-render hooks
            if (cardName === 'experience') initTimeline();
            if (cardName === 'forecasting') { initProfitChart(); initForecastStats(); }
            if (cardName === 'hottakes') initExpandedTakesFilters();
            if (cardName === 'countdowns') startExpandedCountdownTick();
            if (cardName === 'blog') { loadExpandedGuestbook(); loadApiBlogPosts(); guestbookLoaded = true; }

            // Track
            fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event: 'pageview', value: cardName }) }).catch(() => {});
        }

        function initTimeline() {
            const line = document.getElementById('tl-line');
            const nodes = document.querySelectorAll('.tl-node');
            if (!line || !nodes.length) return;

            // Draw the line
            requestAnimationFrame(() => {
                line.classList.add('drawn');
            });

            // Stagger-reveal each node
            nodes.forEach((node, i) => {
                setTimeout(() => {
                    node.classList.add('visible');
                }, 200 + i * 120);
            });
        }

        function initForecastStats() {
            const bar = document.getElementById('forecast-stats-bar');
            if (!bar) return;

            function countUp(el, target, prefix, suffix, duration) {
                const start = performance.now();
                function tick(now) {
                    const t = Math.min((now - start) / duration, 1);
                    const ease = 1 - Math.pow(1 - t, 3);
                    const current = Math.round(target * ease);
                    el.textContent = prefix + current.toLocaleString() + suffix;
                    if (t < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
            }

            Promise.all([
                fetch('https://api.manifold.markets/v0/user/JeromeHPowell').then(r => r.json()),
                fetch('https://api.manifold.markets/v0/get-user-portfolio?userId=' + MANIFOLD_USER_ID).then(r => r.json())
            ]).then(([user, portfolio]) => {
                const networthEl = document.getElementById('forecast-stat-networth');
                const profitEl = document.getElementById('forecast-stat-profit');
                const streakEl = document.getElementById('forecast-stat-streak');
                const dailyEl = document.getElementById('forecast-stat-daily');
                const marketsEl = document.getElementById('forecast-stat-markets');

                if (networthEl) {
                    const netWorth = Math.round((portfolio.balance || 0) + (portfolio.investmentValue || 0));
                    countUp(networthEl, netWorth, 'M$', '', 1200);
                }
                if (profitEl) {
                    // profit isn't in the portfolio endpoint; calculate from balance + investment - deposits
                    const totalProfit = Math.round((portfolio.balance || 0) + (portfolio.investmentValue || 0) - (portfolio.totalDeposits || 0));
                    const sign = totalProfit >= 0 ? '+' : '-';
                    countUp(profitEl, Math.abs(totalProfit), sign + 'M$', '', 1200);
                    if (totalProfit >= 0) profitEl.classList.add('positive');
                    else profitEl.classList.add('negative');
                }
                if (streakEl && user.currentBettingStreak) {
                    countUp(streakEl, user.currentBettingStreak, '', 'd', 900);
                }
                if (dailyEl) {
                    const dailyProfit = Math.round(portfolio.dailyProfit || 0);
                    const dsign = dailyProfit >= 0 ? '+' : '-';
                    countUp(dailyEl, Math.abs(dailyProfit), dsign + 'M$', '/d', 1000);
                    if (dailyProfit >= 0) dailyEl.classList.add('positive');
                    else dailyEl.classList.add('negative');
                }
                if (marketsEl) {
                    const traders = user.creatorTraders?.allTime || 0;
                    countUp(marketsEl, traders, '', '', 900);
                }

                bar.classList.add('loaded');
            }).catch(() => {
                const networthEl = document.getElementById('forecast-stat-networth');
                const profitEl = document.getElementById('forecast-stat-profit');
                const streakEl = document.getElementById('forecast-stat-streak');
                if (networthEl) networthEl.textContent = 'M$61,748';
                if (profitEl) profitEl.textContent = '+M$38,360';
                if (streakEl) streakEl.textContent = '220d';
                const marketsEl = document.getElementById('forecast-stat-markets');
                if (marketsEl) marketsEl.textContent = '1,222';
                const dailyEl = document.getElementById('forecast-stat-daily');
                if (dailyEl) dailyEl.textContent = '+M$1,005/d';
                bar.classList.add('loaded');
            });
        }

        function initProfitChart() {
            const canvas = document.getElementById('forecast-chart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const wrap = document.getElementById('forecast-chart-wrap');
            const tooltip = document.getElementById('forecast-chart-tooltip');
            const statEl = document.getElementById('forecast-chart-stat');
            const startLabel = document.getElementById('forecast-chart-start');
            const endLabel = document.getElementById('forecast-chart-end');

            // Hi-DPI
            const rect = canvas.parentElement.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;
            canvas.style.width = rect.width + 'px';
            canvas.style.height = rect.height + 'px';
            ctx.scale(dpr, dpr);
            const W = rect.width;
            const H = rect.height;

            fetch('https://api.manifold.markets/v0/get-user-portfolio-history?userId=' + MANIFOLD_USER_ID + '&period=allTime')
                .then(r => r.json())
                .then(data => {
                    if (!data.length) return;

                    // Extract profit series
                    const points = data.map(d => ({ t: d.timestamp, v: d.profit || 0 }));
                    const profits = points.map(p => p.v);
                    const minP = Math.min(...profits);
                    const maxP = Math.max(...profits);
                    const range = maxP - minP || 1;
                    const pad = { top: 12, bottom: 20, left: 0, right: 0 };
                    const chartW = W - pad.left - pad.right;
                    const chartH = H - pad.top - pad.bottom;

                    // Current profit for stat display
                    const currentProfit = Math.round(profits[profits.length - 1]);
                    if (statEl) {
                        statEl.textContent = (currentProfit >= 0 ? '+' : '') + 'M$' + Math.abs(currentProfit).toLocaleString();
                        if (currentProfit < 0) statEl.classList.add('negative');
                    }
                    // Also update the stats bar profit with accurate history data
                    const barProfitEl = document.getElementById('forecast-stat-profit');
                    if (barProfitEl) {
                        barProfitEl.textContent = (currentProfit >= 0 ? '+' : '') + 'M$' + Math.abs(currentProfit).toLocaleString();
                        barProfitEl.classList.remove('positive', 'negative');
                        barProfitEl.classList.add(currentProfit >= 0 ? 'positive' : 'negative');
                    }

                    // Date range labels
                    const fmt = (ts) => new Date(ts).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
                    if (startLabel) startLabel.textContent = fmt(points[0].t);
                    if (endLabel) endLabel.textContent = fmt(points[points.length - 1].t);

                    function xOf(i) { return pad.left + (i / (points.length - 1)) * chartW; }
                    function yOf(v) { return pad.top + chartH - ((v - minP) / range) * chartH; }

                    // Zero line
                    if (minP < 0 && maxP > 0) {
                        const zeroY = yOf(0);
                        ctx.strokeStyle = document.documentElement.getAttribute('data-theme') === 'dark'
                            ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
                        ctx.lineWidth = 1;
                        ctx.setLineDash([4, 4]);
                        ctx.beginPath();
                        ctx.moveTo(pad.left, zeroY);
                        ctx.lineTo(W - pad.right, zeroY);
                        ctx.stroke();
                        ctx.setLineDash([]);
                    }

                    // Gradient fill
                    const grad = ctx.createLinearGradient(0, pad.top, 0, H - pad.bottom);
                    const isUp = currentProfit >= 0;
                    if (isUp) {
                        grad.addColorStop(0, 'rgba(34, 68, 204, 0.18)');
                        grad.addColorStop(1, 'rgba(34, 68, 204, 0)');
                    } else {
                        grad.addColorStop(0, 'rgba(220, 38, 38, 0)');
                        grad.addColorStop(1, 'rgba(220, 38, 38, 0.18)');
                    }

                    // Area fill
                    ctx.beginPath();
                    ctx.moveTo(xOf(0), yOf(points[0].v));
                    for (let i = 1; i < points.length; i++) {
                        ctx.lineTo(xOf(i), yOf(points[i].v));
                    }
                    ctx.lineTo(xOf(points.length - 1), H - pad.bottom);
                    ctx.lineTo(pad.left, H - pad.bottom);
                    ctx.closePath();
                    ctx.fillStyle = grad;
                    ctx.fill();

                    // Line
                    ctx.beginPath();
                    ctx.moveTo(xOf(0), yOf(points[0].v));
                    for (let i = 1; i < points.length; i++) {
                        ctx.lineTo(xOf(i), yOf(points[i].v));
                    }
                    ctx.strokeStyle = isUp ? '#2244cc' : '#dc2626';
                    ctx.lineWidth = 2;
                    ctx.lineJoin = 'round';
                    ctx.stroke();

                    // End dot
                    const lastX = xOf(points.length - 1);
                    const lastY = yOf(points[points.length - 1].v);
                    ctx.beginPath();
                    ctx.arc(lastX, lastY, 4, 0, Math.PI * 2);
                    ctx.fillStyle = isUp ? '#2244cc' : '#dc2626';
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(lastX, lastY, 2, 0, Math.PI * 2);
                    ctx.fillStyle = '#fff';
                    ctx.fill();

                    // Interactive tooltip on hover
                    const container = canvas.parentElement;
                    container.addEventListener('mousemove', (e) => {
                        const br = canvas.getBoundingClientRect();
                        const mx = e.clientX - br.left;
                        const idx = Math.round(((mx - pad.left) / chartW) * (points.length - 1));
                        if (idx < 0 || idx >= points.length) { tooltip.style.display = 'none'; return; }

                        const p = points[idx];
                        const px = xOf(idx);
                        const py = yOf(p.v);
                        const date = new Date(p.t).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                        const val = (p.v >= 0 ? '+' : '') + 'M$' + Math.round(Math.abs(p.v)).toLocaleString();
                        tooltip.innerHTML = '<div>' + date + '</div><div style="font-weight:700;color:' + (p.v >= 0 ? '#2244cc' : '#dc2626') + '">' + val + '</div>';
                        tooltip.style.display = 'block';
                        tooltip.style.left = Math.min(px + 10, W - 120) + 'px';
                        tooltip.style.top = (py - 50) + 'px';

                        // Crosshair
                        ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
                        // Redraw zero line
                        if (minP < 0 && maxP > 0) {
                            const zeroY = yOf(0);
                            ctx.strokeStyle = document.documentElement.getAttribute('data-theme') === 'dark'
                                ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
                            ctx.lineWidth = 1;
                            ctx.setLineDash([4, 4]);
                            ctx.beginPath();
                            ctx.moveTo(pad.left, zeroY);
                            ctx.lineTo(W - pad.right, zeroY);
                            ctx.stroke();
                            ctx.setLineDash([]);
                        }
                        // Redraw area
                        ctx.beginPath();
                        ctx.moveTo(xOf(0), yOf(points[0].v));
                        for (let j = 1; j < points.length; j++) ctx.lineTo(xOf(j), yOf(points[j].v));
                        ctx.lineTo(xOf(points.length - 1), H - pad.bottom);
                        ctx.lineTo(pad.left, H - pad.bottom);
                        ctx.closePath();
                        ctx.fillStyle = grad;
                        ctx.fill();
                        // Redraw line
                        ctx.beginPath();
                        ctx.moveTo(xOf(0), yOf(points[0].v));
                        for (let j = 1; j < points.length; j++) ctx.lineTo(xOf(j), yOf(points[j].v));
                        ctx.strokeStyle = isUp ? '#2244cc' : '#dc2626';
                        ctx.lineWidth = 2;
                        ctx.lineJoin = 'round';
                        ctx.stroke();
                        // Vertical crosshair
                        ctx.strokeStyle = document.documentElement.getAttribute('data-theme') === 'dark'
                            ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.1)';
                        ctx.lineWidth = 1;
                        ctx.setLineDash([3, 3]);
                        ctx.beginPath();
                        ctx.moveTo(px, pad.top);
                        ctx.lineTo(px, H - pad.bottom);
                        ctx.stroke();
                        ctx.setLineDash([]);
                        // Hover dot
                        ctx.beginPath();
                        ctx.arc(px, py, 5, 0, Math.PI * 2);
                        ctx.fillStyle = isUp ? '#2244cc' : '#dc2626';
                        ctx.fill();
                        ctx.beginPath();
                        ctx.arc(px, py, 2.5, 0, Math.PI * 2);
                        ctx.fillStyle = '#fff';
                        ctx.fill();
                    });
                    container.addEventListener('mouseleave', () => {
                        tooltip.style.display = 'none';
                        // Final clean redraw
                        ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
                        if (minP < 0 && maxP > 0) {
                            const zeroY = yOf(0);
                            ctx.strokeStyle = document.documentElement.getAttribute('data-theme') === 'dark'
                                ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
                            ctx.lineWidth = 1;
                            ctx.setLineDash([4, 4]);
                            ctx.beginPath();
                            ctx.moveTo(pad.left, zeroY);
                            ctx.lineTo(W - pad.right, zeroY);
                            ctx.stroke();
                            ctx.setLineDash([]);
                        }
                        ctx.beginPath();
                        ctx.moveTo(xOf(0), yOf(points[0].v));
                        for (let j = 1; j < points.length; j++) ctx.lineTo(xOf(j), yOf(points[j].v));
                        ctx.lineTo(xOf(points.length - 1), H - pad.bottom);
                        ctx.lineTo(pad.left, H - pad.bottom);
                        ctx.closePath();
                        ctx.fillStyle = grad;
                        ctx.fill();
                        ctx.beginPath();
                        ctx.moveTo(xOf(0), yOf(points[0].v));
                        for (let j = 1; j < points.length; j++) ctx.lineTo(xOf(j), yOf(points[j].v));
                        ctx.strokeStyle = isUp ? '#2244cc' : '#dc2626';
                        ctx.lineWidth = 2;
                        ctx.lineJoin = 'round';
                        ctx.stroke();
                        ctx.beginPath();
                        ctx.arc(lastX, lastY, 4, 0, Math.PI * 2);
                        ctx.fillStyle = isUp ? '#2244cc' : '#dc2626';
                        ctx.fill();
                        ctx.beginPath();
                        ctx.arc(lastX, lastY, 2, 0, Math.PI * 2);
                        ctx.fillStyle = '#fff';
                        ctx.fill();
                    });
                })
                .catch(() => {
                    ctx.font = '13px Inter, sans-serif';
                    ctx.fillStyle = '#999';
                    ctx.textAlign = 'center';
                    ctx.fillText('Could not load chart data', W / 2, H / 2);
                });
        }

        function collapseCard() {
            const overlay = document.getElementById('expand-overlay');
            overlay.classList.remove('active');
            setTimeout(() => { overlay.style.display = 'none'; }, 300);
            document.body.style.overflow = '';
            currentExpandedCard = null;
            if (window.location.hash) history.pushState(null, '', window.location.pathname);
        }

        // Escape key + back button
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && currentExpandedCard) collapseCard();
        });

        window.addEventListener('popstate', (e) => {
            if (e.state && e.state.card) {
                expandCard(e.state.card);
            } else if (currentExpandedCard) {
                collapseCard();
            }
        });

        // Deep link on load
        if (window.location.hash) {
            const card = window.location.hash.substring(1);
            if (expandedContent[card]) {
                // Wait for page load
                setTimeout(() => expandCard(card), 100);
            }
        }

        // =============================================
        // API DATA — Hot Takes + Countdowns
        // =============================================
        function renderTakesWall(takes) {
            if (!takes.length) return '<div style="text-align:center;padding:2rem;color:var(--text-light);font-style:italic">No takes yet.</div>';
            return takes.map((t, i) => `
                <div class="take-card take-color-${i % 6}" style="transform:rotate(${(Math.random() - 0.5) * 2}deg)">
                    <div class="take-text">${t.text}</div>
                    <div class="take-footer">
                        <span class="take-category">${t.category}</span>
                        <span class="take-spice">${t.spiciness}/5</span>
                    </div>
                </div>
            `).join('');
        }

        function initExpandedTakesFilters() {
            const bar = document.getElementById('expand-filter-bar');
            if (!bar || !allTakesData.length) return;
            const cats = [...new Set(allTakesData.map(t => t.category))];
            bar.innerHTML = '<button class="filter-pill active" data-cat="all">All</button>' +
                cats.map(c => `<button class="filter-pill" data-cat="${c}">${c}</button>`).join('');
            bar.querySelectorAll('.filter-pill').forEach(btn => {
                btn.addEventListener('click', () => {
                    bar.querySelectorAll('.filter-pill').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    const cat = btn.dataset.cat;
                    const filtered = cat === 'all' ? allTakesData : allTakesData.filter(t => t.category === cat);
                    document.getElementById('expand-takes-wall').innerHTML = renderTakesWall(filtered);
                });
            });
        }

        function renderCountdownCards(countdowns) {
            if (!countdowns.length) return '<div style="text-align:center;padding:2rem;color:var(--text-light);font-style:italic">No countdowns yet.</div>';
            const now = Date.now();
            const upcoming = countdowns.filter(c => new Date(c.date).getTime() > now);
            const past = countdowns.filter(c => new Date(c.date).getTime() <= now);
            let html = '';
            upcoming.forEach(c => {
                const diff = new Date(c.date).getTime() - now;
                const d = Math.floor(diff / 86400000);
                const h = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
                const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
                const s = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
                const target = new Date(c.date);
                const created = new Date(c.created || c.date);
                const total = target.getTime() - created.getTime();
                const elapsed = now - created.getTime();
                const pct = total > 0 ? Math.min(100, (elapsed / total) * 100) : 0;
                html += `<div class="countdown-card" data-date="${c.date}">

                    <div class="countdown-title">${escapeHtml(c.title)}</div>
                    <div class="countdown-date">${target.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</div>
                    <div class="countdown-timer" data-target="${c.date}">
                        <div class="countdown-unit"><div class="countdown-number" data-unit="days">${d}</div><div class="countdown-label">Days</div></div>
                        <div class="countdown-unit"><div class="countdown-number" data-unit="hours">${h}</div><div class="countdown-label">Hours</div></div>
                        <div class="countdown-unit"><div class="countdown-number" data-unit="minutes">${m}</div><div class="countdown-label">Min</div></div>
                        <div class="countdown-unit"><div class="countdown-number" data-unit="seconds">${s}</div><div class="countdown-label">Sec</div></div>
                    </div>
                    <div class="countdown-progress" style="width:${pct}%"></div>
                </div>`;
            });
            if (past.length) {
                html += '<div class="section-divider">Already Happened</div>';
                past.reverse().forEach(c => {
                    html += `<div class="countdown-card past">
    
                        <div class="countdown-title">${escapeHtml(c.title)}</div>
                        <div class="countdown-date">${new Date(c.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</div>
                        <div class="countdown-done">Happened!</div>
                    </div>`;
                });
            }
            return html;
        }

        function startExpandedCountdownTick() {
            const tickFn = () => {
                if (currentExpandedCard !== 'countdowns') return;
                const grid = document.getElementById('expand-countdown-grid');
                if (!grid) return;
                grid.querySelectorAll('.countdown-timer').forEach(timer => {
                    const t = new Date(timer.dataset.target).getTime() - Date.now();
                    if (t <= 0) return;
                    timer.querySelector('[data-unit="days"]').textContent = Math.floor(t / 86400000);
                    timer.querySelector('[data-unit="hours"]').textContent = String(Math.floor((t % 86400000) / 3600000)).padStart(2, '0');
                    timer.querySelector('[data-unit="minutes"]').textContent = String(Math.floor((t % 3600000) / 60000)).padStart(2, '0');
                    timer.querySelector('[data-unit="seconds"]').textContent = String(Math.floor((t % 60000) / 1000)).padStart(2, '0');
                });
                setTimeout(tickFn, 1000);
            };
            tickFn();
        }

        // Blog articles data (for expanded blog view)
        const blogArticles = {
            'peoples-edict': {
                title: "People's Edict",
                date: 'May 23, 2025',
                readTime: '5 min read',
                tags: ['Essay'],
                image: '2500.webp',
                body: `<p>I wrote an interesting on-demand essay in English on power and strife. This is what I came up with in 50 minutes. Not pure gold, but it resonates.</p>
                    <p>Authority is inherently meant to be challenged. Since the dawn of time, power struggles have transcended not only humans but also the most basic of animals. However, for such a primal topic, it has been fraught with various philosophies and theses on how to govern while allowing the populace to have agency over themselves and their decisions. Authority was created to centralize decision-making. It has existed in many forms as the world has evolved: the leader of the tribe, the king, and now the head of state, all having to balance on a tightrope of power and public approval. Without much of either, the leader tends to, well, not lead. Nevertheless, people have both the right and the will to challenge authority they deem unjust; the question is when to do so. Instead of writing a philosophical and motivational thesis, I believe we must be pragmatic about challenging authority. Authority should be challenged only when it is both a necessity and, more importantly, achievable. While opposition to a force larger than ourselves may seem the moral and right thing to do, one should only challenge authority when they believe change is either imminent or attainable.</p>
                    <p>This claim, a pragmatic approach to opposition, is most exhaustively demonstrated in "Raisin in the Sun." During a time of great strife and burden for Black homeownership, the Youngers could have organized a movement at the federal level to outlaw redlining, a far bigger accomplishment than anything they achieved in the book. The protest would have been noble; however, the Youngers realized that the most effective way to challenge authority was to stay and fight the battle they could win. By fighting this small battle in a tight-knit neighbourhood, they presumably helped the narrative of Black homeownership. In this way, they were successful, while Karl Linder was not nearly the tip of the spear; they understood what was within the scope of their abilities and challenged the preconceived, illogical notions about Black homeownership, albeit in a small but significant way.</p>
                    <p>This "fight when you can win" strategy is not only effective in literature; it has real applications to real-life authority. My research project, focused on voter turnout in low-propensity Black neighbourhoods, which presents an enormous challenge in the US; however, the resources and infrastructure required to effect change at a state or nationwide level are immense. Consequently, I attempted to change something at a more achievable level, where challenging authority and policy is much more feasible. Throughout the project, I spoke with mayoral candidates and aldermen who appeared receptive, if not interested, in my idea. While challenging authority was not the core of the project, the narrative of "figuring out a winnable fight" and challenging authority only when necessary is central to the research I conducted.</p>
                    <p>Lastly, and in all truthfulness, my least relevant or persuasive piece of evidence comes from "Romeo and Juliet." While they do challenge authority and nearly succeed, the story ends in heartbreak. The challenge to the wealthiest and most influential individuals results in the death of the two lovers, both opposing the omnipotent authority of their parents. Although fictional, the tale illustrates what occurs in real life when individuals blindly attack authority: death and bloodshed, ultimately empowering the leader to persist, the antithesis of the original goal of those who opposed them.</p>
                    <p>These stories both present cautionary tales and ideal models for opposing authority. They suggest that, when necessary and applicable, authority should be questioned. This thesis provides an unparalleled application to modern life; with battles over power raging throughout the world, the question of when to oppose authority is not merely theoretical or meant to be taught in a classroom, but is relevant to the lives and deaths of millions.</p>`
            },
            'median-voter-theory': {
                title: "The Conflation Between Median Voter Theory and Trump's Win",
                date: 'January 8, 2025',
                readTime: '6 min read',
                tags: ['Politics'],
                image: '1721605711463.webp',
                body: `<p><strong>How the Trump Campaign Used an Obscure Political Science Concept to Move the Electorate</strong></p>
                    <p><em>By: Ryan J. McComb</em></p>
                    <p>In the aftermath of the election, a wave of analysis has swept through the Democratic Party and political pundits alike. The reasoning spans from Democratic rancour over Biden's resignation to the lack of time and preparation that the Harris campaign had at its disposal. However, unlike its predecessors, this election was shaped by a concept older than the United States itself.</p>
                    <p>The term Median Voter Theory was coined by Duncan Black in the mid-1900s and refers to the idea that in a first-past-the-post (plurality voting) system, a "Median Voter" would decide the election. However hypothetical, this voter would represent the collective opinion of the country's policy positions. Due in part to the obscurity of the concept, it is commonly misconceived that the "voter" would split policy positions evenly down the middle. For much of U.S. policy, they would\u2014or come close. However, on issues like abortion or immigration, their "median" view might lean left or right of centre, respectively. This dynamic often forces major party candidates to adopt policy and rhetoric that is often far different or antithetical to primary policy in order to appeal to a wider range of voters in a national election.</p>
                    <h2>The Strategic Exploitation</h2>
                    <p>In this election, the Trump campaign identified a unique opportunity to tactically exploit Median Voter Theory in action: leveraging Kamala Harris\u2019 2020 bid for president to position her as out of touch with the "median voter." The first few weeks of the "switch" were a tumultuous time for both campaigns. On one side, the Trump team scrambled to create media and strategy for the new opponent. On the other side, the Democratic campaign underwent upheaval, creating entirely new media and advertisements solely for publicity. While both efforts generated effective publicity for their respective campaigns (albeit a bit differently), Harris\u2019 pre-existing favourability challenges suggest deeper issues.</p>
                    <p>Examining her public perception before the ticket change reveals a critical vulnerability that shaped the election\u2019s trajectory.</p>
                    <p><em>Per: FiveThirtyEight</em></p>
                    <p>Almost immediately after inauguration, her favourability began to slip into the negatives, slowly rising and plateauing at a remarkable 17.4 points underwater. Unlike Trump, who maintained a \u221210 point favourability for a while coming into the election, Harris had nearly three years for her discontent to marinate throughout the American people. This was not fully unexpected; Vice Presidents take much more blame and much less credit proportionally than their dynamic counterparts. Her declining favourability reflected both short-term events and long-term perceptions. While discontent with the administration\u2014particularly following the Afghanistan withdrawal\u2014played a role, a more enduring factor was the public\u2019s lingering impression of her lackluster showing and progressive policies during the 2020 primaries.</p>
                    <p>In 2020, she was an extremely different candidate than the one she tried to be in 2024. All credit given, you need different pieces of policy that will win you a primary. However, on the stage, she was far left. With this being her first exposure to the broader American public, she did see a temporary bump due to the partisan nature of her messaging in the primaries and the impending election, where few Democratic voters would say that she was an unfavourable choice. Even so, her policies soured among much of her Democratic contingent as well.</p>
                    <h2>Running with the Data</h2>
                    <p>Armed with the same data that is at the press of a few buttons on your laptop, the Trump campaign took it and ran. They pushed out tens of millions of dollars\u2019 worth of advertisements just playing and capitalising upon clips of town halls and debates during her primary process. One of the key harangues was "Kamala is for They/Them," capitalising upon comments made during her run in the primaries and early in her tenure.</p>
                    <p><em>Per: Donald J. Trump</em></p>
                    <p>This wasn\u2019t accidental. Reinforcing the messages (especially anti-trans sentiments that have become a slight advantage for the Republicans) that were said to win a primary had a very different effect on an already polarised electorate. Remember, the median voter types tend to match the quintessentially fought-over "swing voters." Reinforcing an already advantageous message to a group of people with quasi-malleable opinions was a great strategy. While Median Voter Theory does lack a spatial awareness of the issues presented (basically how much the issues matter, and to whom), it does model voting in a relatively realistic fashion. Even though it was subliminal, Trump mentioned her tax policy (something of paramount importance to voters) while focusing upon her extreme stances on trans-sports and trans-rights.</p>
                    <h2>The Culmination</h2>
                    <p>A culmination of the advertisement as aforementioned, along with countless others, propelled a win among the "swingiest" groups\u2014notably Latinos. Using the already marinated national image and clips from her primary run, Trump and his contingent pushed Harris just far enough from the median in many of her policies to get the votes from the crucial swing voters. This was only made easier by many of the preconceived notions that Harris had left voters with during her first national run.</p>
                    <p>To visualise this, let\u2019s suppose that tax policy opinions tend to lean liberal among the public. We can demonstrate what a few advertisements and some old policy choices (made to win a primary) would do to a voter\u2019s opinion of the candidates on the issue.</p>
                    <p>Albeit a crude image, you can see that with a bit of reestablishment of some unfavourable policy choices, Trump is able to win that specific category among the "median voter." Inherently, you have to win many categories, but some stand out. Trump mainly attacked Harris on her far-left policy in regards to the border and some of her proposals for where to spend tax dollars that is germane to the economy in voting. Seeing as these categories play outsized roles in the electorate, a blanket of ads over every issue was not necessary.</p>
                    <h2>Looking Back</h2>
                    <p>With all of that said, it has to be remembered that no one candidate loses due to one, two, or even three factors. In Harris\u2019 case, her semi-extreme policy positions from the 2020 election seem to have stuck with the voter. Additionally, all politicians go through some type of primary process and stray to the partisans (to whom they are rightfully appealing). However, candidates that are threatened by previous words tend to be running for president, inherently giving a chance to change policy directly after the primaries. Nevertheless, Harris\u2019 case presents a uniqueness unseen before; her policy from her first national appearances was just ripe enough for remembrance while also being far enough from the present for attack advertisements from the Trump Team to fill in the blanks on her "policy goals."</p>
                    <p>Could this have been avoided? Maybe. Even a primary process would have likely crowned her as heir apparent; however, she would have been given years, not weeks, to establish herself on the national stage and push back and reestablish her brand state-by-state. How would she have acquired more time? Just as so many post-mortems have said, Biden should have ceded; it all comes back to the big man in the end.</p>
                    <hr>
                    <p><em>Image Credit: <a href="https://www.axios.com/politics-policy/2024/07/22">Axios</a></em></p>
                    <p><sup>1</sup> Even with his mercurial nature, he managed to keep his approval relatively the same throughout the election cycle.</p>
                    <p><sup>2</sup> He now sits at close to 0, with an official rating of \u22120.3. This is well within the margin of error, so it\u2019s basically a wash.</p>
                    <p><sup>3</sup> <a href="https://www.pbs.org/wgbh/americanexperience/features/american-vice-president-evolving-vice-presidency">PBS \u2013 The Evolving Vice Presidency</a></p>
                    <p><sup>4</sup> <a href="https://www.vox.com/2019/11/20/20953284/kamala-harris-polls-2020-election">Vox \u2013 Kamala Harris Polls, 2020 Election</a></p>
                    <p><sup>5</sup> <a href="https://en.wikipedia.org/wiki/Spatial_voting">Wikipedia \u2013 Spatial Voting</a></p>
                    <p><sup>6</sup> <a href="https://www.pewresearch.org/global/2024/03/13/economic-and-policy-changes/">Pew Research \u2013 Economic and Policy Changes</a></p>
                    <p><sup>7</sup> <a href="https://www.pewresearch.org/politics/2024/09/09/issues-and-the-2024-election/">Pew Research \u2013 Issues and the 2024 Election</a></p>
                    <p><sup>8</sup> Given that the others don\u2019t need to worry because they tend to be on the sidelines, or behind presidential policy, not running for office.</p>`
            },
            'nsa-surveillance': {
                title: "Resolution on State Interception of Communications: Notwithstanding National Security",
                date: 'September 29, 2024',
                readTime: '7 min read',
                tags: ['Essay'],
                body: `<p><em>I wrote this essay in eighth grade, so the quality may be subpar.</em></p>
                    <p>In an age where digital technology permeates every facet of modern life, the issue of government surveillance has emerged as a contentious battleground between national security imperatives and individual (and constitutional) privacy rights. At the forefront of this debate stands the National Security Agency (NSA), a governmental body entrusted with the formidable task of safeguarding the nation against foreign and domestic threats. It is a good bet these days that almost anyone has some internet-enabled, message-capable device on them at all times. When messages are sent through these devices, people expect them to be secure, and, for all intents and purposes, they are. Although secure, in recent times, operations run by the NSA, respectively PRISM, XKeyscore, and Upstream have been intercepting vast quantities of communications metadata from US citizens. However, there is a strong possibility that the NSA has picked up text messages or calls from most US citizens through FISA (Foreign Intelligence Surveillance Act) or an NSL (National Security Letter). Even while enticing for national security, the intentional censorship and oversight of personal and private-enterprise communications without an official warrant is not only immoral but outright unconstitutional. The staggering amount of precedent and stare decisis demonstrates the necessity of private communications in personal and enterprise environments.</p>
                    <p>Even though debate and argument can be helpful and get discourse far, legal precedence is indubitably the most powerful and compelling to initiate change. Since our nation\u2019s inception, privacy has been a central credo of our laws and doctrine. The quantity of doctrine of judicial precedent is unrivalled in almost any other constitutional law debate. EO (Executive Order) 12333 proclaims that intel agencies are "restricted in collecting intelligence information against US citizens" and require warrants to tap or collect data. Sadly, after the "Patriot Act" was put in place, many of these liberties started to crumble. NSLs (National Security Letters) can let FBI agents obtain personal and private-enterprise information without a warrant from a judge. These actions were unequivocally and unmistakably unconstitutional. These measures spurred some insiders to release a plethora of damning documents to the public, which included the specifications of the surveillance effort in the public realm. Some subsections of the Patriot Act were repealed and declared unconstitutional because "the FBI had no probable cause to issue NSLs." In the end, these so-called NSLs captured only one suspected terrorist. Additionally, the NSL was only used to corroborate evidence, not to catch the aforementioned terrorist actively. As illustrated in this paragraph, this surveillance is not only illegal but useless, with worse-than-dismal results.</p>
                    <p>The second tenet on which this argument is based is regarding public interest. As we live in a democracy, the state has the obligation to act in the people\u2019s best interests. According to a recent AP poll, only 28% of people support the interception of foreign communications. This poll paints a glaring picture that the national appetite to cease government surveillance is growing exponentially compared to after 9/11. The citizens ought to reflect on how Orwellian this society is to be before it takes that form permanently. Even while shielded from public oversight, both the President and inspector general oversee the capacity of the agencies responsible for digital communications metadata. The President appoints a National Security Advisor who advises the President and the Joint Chiefs on the actions of intelligence agencies (domestic, US Department of Homeland Security, and FBI (Federal Bureau of Investigation), or foreign, DIA (Defence Intelligence Agency), CIA (Central Intelligence Agency), and NSA (National Security Agency). The Inspector General can also oversee budgets, among other intelligence duties. Sadly, the reason Americans could not respond to this Orwellian threat was because, well, it was classified. The documents were classified so highly that most people working on active clandestine surveillance did not even know what data they were collecting. The only reason that Edward Snowden could acquire and disseminate the documents was because he was a systems engineer for a CIA contractor. He had tremendous and relatively unprecedented oversight over many files that he and only a few others had ever seen. He had seen so much over his tenure that in his book, he remarks about how once the FBI realized it was him and searched his house, they were going to be scared, not because they knew what Snowden was going to distribute but because he could disseminate every damaging national security document authored in the past ten years. It should not take a person who has to flee to Russia to inform citizens of what is happening to them; it should be a relatively public policy decision not of the state but of the citizens.</p>
                    <p>While the Patriot Act did have good intentions, it was overzealous and thought up by people who were non-compos mentis. The whole country was outraged, and at the time, the act was warranted, temporarily. However, the encroachment of rights was unmistakable and tarnished our history as a country and a democracy. That brings the argument to its third tenet: the omnipotent rights granted to the government in the Patriot Act never should have been implemented for so long. The systemic and systematic surveillance of US citizens happened for almost a decade. We can also reflect on past oversight failures. Regarding these relatively unprecedented activities, HUAC (House Un-American Activities Committee) was one of the most comparable state-sanctioned actions. Not all, but certainly most Americans look at HUAC with disdain and contempt. Within our domestic schools, it is taught as a black mark on our nation\u2019s history. Even if used in moderation, NSLs and censorship can slowly corrupt the morals and ideals of a country, just as excessive surveillance did during the Red Scare.</p>
                    <p>The core question of this whole debate entails whether a federal employee serving in the citizens\u2019 best interests should need an official judge-ordered precept for surveillance. What about if it is for national security grounds? Or an impending terrorist threat? These are questions with imperceptible answers that require careful examination and context. Even though these are nuanced matters, nobody who is a citizen of the state deserves to be spied on without an official warrant from a judge. Even when most citizens agree that surveillance is not in their personal or business interests they are helpless to the whims of the "black ops" and highly kept secrets of these shady highly-funded government agencies. Almost all damning documents are protected from FOIA with immense classification measures along with the agents not being permitted to speak on the topic in a deposition or affidavit. All that prevents legal and PR repercussions. In full summary, US citizens should unequivocally not be surveilled by the people who have put their hands on a Bible to protect them, their interests domestically, and their security. Censorship is a slippery slope, and we are slowly (and accelerating) into a much more surveillance state of society.</p>
                    <h2>Works Cited</h2>
                    <ul>
                        <li>American Civil Liberties Union. \u201CNSA Surveillance.\u201D <em>American Civil Liberties Union</em>, 2013, <a href="http://www.aclu.org/issues/national-security/privacy-and-surveillance/nsa-surveillance">www.aclu.org</a>.</li>
                        <li>Bureau of Justice Assistance. \u201CThe Foreign Intelligence Surveillance Act of 1978 (FISA).\u201D <em>Bureau of Justice Assistance</em>, <a href="https://bja.ojp.gov/program/it/privacy-civil-liberties/authorities/statutes/1286">bja.ojp.gov</a>.</li>
                        <li>Electronic Frontier Foundation. \u201CNSA Spying.\u201D <em>Electronic Frontier Foundation</em>, <a href="http://www.eff.org/nsa-spying">www.eff.org</a>.</li>
                        <li>\u201CIntelligence Surveillance.\u201D <em>EPIC \u2013 Electronic Privacy Information Center</em>, <a href="https://epic.org/issues/surveillance-oversight/intelligence-surveillance/">epic.org</a>.</li>
                        <li>Nakashima, Ellen. \u201CNSA Surveillance Program Still Raises Privacy Concerns Years after Exposure, Member of Privacy Watchdog Says.\u201D <em>Washington Post</em>, 29 June 2021, <a href="http://www.washingtonpost.com/national-security/nsa-surveillance-xkeyscore-privacy/2021/06/29/b2134e7a-d685-11eb-a53a-3b5450fdca7a_story.html">www.washingtonpost.com</a>.</li>
                        <li>Taitz, Sarah. \u201CFive Things to Know about NSA Mass Surveillance and the Coming Fight in Congress.\u201D <em>American Civil Liberties Union</em>, 11 Apr. 2023, <a href="http://www.aclu.org/news/national-security/five-things-to-know-about-nsa-mass-surveillance-and-the-coming-fight-in-congress">www.aclu.org</a>.</li>
                    </ul>`
            }
        };

        function openExpandedArticle(id) {
            const article = blogArticles[id];
            if (!article) return;
            const blogList = document.getElementById('expand-blog-list');
            const blogArticle = document.getElementById('expand-blog-article');
            if (blogList) blogList.classList.add('hidden');
            if (blogArticle) {
                blogArticle.classList.add('active');
                document.getElementById('expand-article-header').innerHTML = '<h1>' + article.title + '</h1><div class="blog-meta"><span class="read-time">' + article.readTime + '</span>' + article.tags.map(t => '<span class="blog-tag">' + t + '</span>').join('') + '<span>' + article.date + '</span></div>';
                const imgHtml = article.image ? '<img src="' + article.image + '" alt="' + article.title + '" class="article-hero-img">' : '';
                document.getElementById('expand-article-body').innerHTML = imgHtml + article.body;
            }
            document.getElementById('expand-overlay').scrollTop = 0;
        }

        function closeExpandedArticle() {
            const blogList = document.getElementById('expand-blog-list');
            const blogArticle = document.getElementById('expand-blog-article');
            if (blogList) blogList.classList.remove('hidden');
            if (blogArticle) blogArticle.classList.remove('active');
            document.getElementById('expand-overlay').scrollTop = 0;
        }

        // Guestbook for expanded blog
        function getAdminToken() {
            return sessionStorage.getItem('admin_token') || '';
        }

        function loadExpandedGuestbook() {
            fetch('/api/guestbook')
                .then(r => r.json())
                .then(entries => {
                    const container = document.getElementById('expand-gb-entries');
                    if (!container) return;
                    if (!entries.length) { container.innerHTML = '<p style="color:var(--text-light);font-size:0.85rem">No entries yet. Be the first!</p>'; return; }
                    const isAdmin = !!getAdminToken();
                    container.innerHTML = entries.slice(0, 20).map(e => {
                        const d = new Date(e.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                        const adminBtns = isAdmin && e.id ? '<div class="gb-entry-actions"><button class="gb-action-btn" onclick="editGuestbookEntry(\'' + e.id + '\',this)" title="Edit">Edit</button><button class="gb-action-btn gb-action-delete" onclick="deleteGuestbookEntry(\'' + e.id + '\')" title="Delete">Delete</button></div>' : '';
                        return '<div class="gb-entry" data-id="' + (e.id || '') + '"><div class="gb-entry-header"><span class="gb-entry-name">' + escapeHtml(e.name) + '</span><span class="gb-entry-date">' + d + '</span></div><div class="gb-entry-msg">' + escapeHtml(e.message) + '</div>' + adminBtns + '</div>';
                    }).join('');
                }).catch(() => {});
        }

        function deleteGuestbookEntry(id) {
            if (!confirm('Delete this guestbook entry?')) return;
            fetch('/api/guestbook/' + id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + getAdminToken() } })
                .then(r => r.json())
                .then(data => { if (data.ok) loadExpandedGuestbook(); })
                .catch(() => {});
        }

        function editGuestbookEntry(id, btn) {
            const entry = btn.closest('.gb-entry');
            const msgEl = entry.querySelector('.gb-entry-msg');
            const currentMsg = msgEl.textContent;
            const newMsg = prompt('Edit message:', currentMsg);
            if (newMsg === null || newMsg.trim() === '' || newMsg === currentMsg) return;
            fetch('/api/guestbook/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getAdminToken() }, body: JSON.stringify({ message: newMsg.trim() }) })
                .then(r => r.json())
                .then(data => { if (data.ok) loadExpandedGuestbook(); })
                .catch(() => {});
        }

        function signExpandedGuestbook() {
            const form = document.getElementById('expand-gb-form');
            if (!form) return;
            const name = form.querySelector('input[name="name"]').value.trim();
            const message = form.querySelector('textarea[name="message"]').value.trim();
            const status = document.getElementById('expand-gb-status');
            if (!name || !message) { status.textContent = 'Please fill in both fields.'; return; }
            status.textContent = 'Signing...';
            fetch('/api/guestbook', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, message }) })
                .then(r => r.json())
                .then(data => {
                    if (data.ok) { status.textContent = 'Signed! Thanks, ' + name + '!'; form.querySelector('input[name="name"]').value = ''; form.querySelector('textarea[name="message"]').value = ''; loadExpandedGuestbook(); }
                    else { status.textContent = data.error || 'Could not sign.'; }
                }).catch(() => { status.textContent = 'Network error.'; });
        }

        // Load API blog posts into expanded blog view
        function loadApiBlogPosts() {
            const container = document.getElementById('expand-api-posts');
            if (!container) return;
            fetch('/api/blogposts')
                .then(r => r.json())
                .then(posts => {
                    if (!posts.length) return;
                    const isAdmin = !!getAdminToken();
                    container.innerHTML = '<div class="blog-grid">' + posts.map(p => {
                        const d = new Date(p.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
                        const tags = (p.tags || []).map(t => '<span class="blog-tag">' + escapeHtml(t) + '</span>').join('');
                        const adminBtns = isAdmin ? '<div class="blog-card-actions"><button class="gb-action-btn" onclick="event.stopPropagation();editApiBlogPost(\'' + p.id + '\')">Edit</button><button class="gb-action-btn gb-action-delete" onclick="event.stopPropagation();deleteApiBlogPost(\'' + p.id + '\')">Delete</button></div>' : '';
                        return '<div class="blog-card" onclick="openApiArticle(\'' + p.id + '\')"><div class="blog-card-inner"><div class="blog-meta">' + tags + '<span>' + d + '</span></div><h3>' + escapeHtml(p.title) + '</h3><span class="blog-read-link">Read &rarr;</span></div>' + adminBtns + '</div>';
                    }).join('') + '</div>';
                }).catch(() => {});
        }

        function openApiArticle(id) {
            fetch('/api/blogposts')
                .then(r => r.json())
                .then(posts => {
                    const post = posts.find(p => p.id === id);
                    if (!post) return;
                    const blogList = document.getElementById('expand-blog-list');
                    const blogArticle = document.getElementById('expand-blog-article');
                    if (blogList) blogList.classList.add('hidden');
                    if (blogArticle) {
                        blogArticle.classList.add('active');
                        const tags = (post.tags || []).map(t => '<span class="blog-tag">' + escapeHtml(t) + '</span>').join('');
                        const d = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
                        document.getElementById('expand-article-header').innerHTML = '<h1>' + escapeHtml(post.title) + '</h1><div class="blog-meta">' + tags + '<span>' + d + '</span></div>';
                        document.getElementById('expand-article-body').innerHTML = post.body;
                    }
                    document.getElementById('expand-overlay').scrollTop = 0;
                }).catch(() => {});
        }

        function editApiBlogPost(id) {
            const newTitle = prompt('New title:');
            if (!newTitle) return;
            const newBody = prompt('New body (HTML):');
            if (!newBody) return;
            fetch('/api/blogposts/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getAdminToken() }, body: JSON.stringify({ title: newTitle, body: newBody }) })
                .then(r => r.json())
                .then(data => { if (data.ok) loadApiBlogPosts(); })
                .catch(() => {});
        }

        function deleteApiBlogPost(id) {
            if (!confirm('Delete this blog post?')) return;
            fetch('/api/blogposts/' + id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + getAdminToken() } })
                .then(r => r.json())
                .then(data => { if (data.ok) loadApiBlogPosts(); })
                .catch(() => {});
        }

        // Load API data on page load
        function loadSiteData() {
            // Hot takes
            fetch('/api/hottakes')
                .then(r => r.json())
                .then(takes => {
                    allTakesData = takes;
                    // Populate preview card
                    if (takes.length) {
                        const random = takes[Math.floor(Math.random() * takes.length)];
                        const previewText = document.getElementById('hottake-preview-text');
                        const previewSpice = document.getElementById('hottake-preview-spice');
                        const previewFooter = document.getElementById('hottake-preview-footer');
                        if (previewText) previewText.textContent = '"' + random.text + '"';
                        if (previewSpice) previewSpice.textContent = random.spiciness + '/5';
                        if (previewFooter) previewFooter.textContent = '+ ' + (takes.length - 1) + ' more takes \u2192';
                    }
                }).catch(() => {});

            // Countdowns
            fetch('/api/countdowns')
                .then(r => r.json())
                .then(data => {
                    allCountdownsData = data;
                    // Populate preview card with next upcoming
                    const now = Date.now();
                    const upcoming = data.filter(c => new Date(c.date).getTime() > now);
                    if (upcoming.length) {
                        const next = upcoming[0];
                        const titleEl = document.getElementById('cd-preview-title');
                        const dateEl = document.getElementById('cd-preview-date');
                        if (titleEl) titleEl.textContent = next.title;
                        if (dateEl) dateEl.textContent = new Date(next.date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                        // Start live ticker
                        function tickPreview() {
                            const diff = new Date(next.date).getTime() - Date.now();
                            if (diff <= 0) return;
                            const dEl = document.getElementById('cd-d');
                            const hEl = document.getElementById('cd-h');
                            const mEl = document.getElementById('cd-m');
                            const sEl = document.getElementById('cd-s');
                            if (dEl) dEl.textContent = Math.floor(diff / 86400000);
                            if (hEl) hEl.textContent = Math.floor((diff % 86400000) / 3600000);
                            if (mEl) mEl.textContent = Math.floor((diff % 3600000) / 60000);
                            if (sEl) sEl.textContent = Math.floor((diff % 60000) / 1000);
                        }
                        tickPreview();
                        setInterval(tickPreview, 1000);
                    }
                }).catch(() => {});
        }

        loadSiteData();


        // =============================================
        // KONAMI CODE EASTER EGG
        // =============================================
        const konamiSequence = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
        let konamiIndex = 0;

        document.addEventListener('keydown', (e) => {
            if (e.key === konamiSequence[konamiIndex]) {
                konamiIndex++;
                if (konamiIndex === konamiSequence.length) {
                    konamiIndex = 0;
                    activateKonami();
                }
            } else {
                konamiIndex = 0;
            }
        });

        function activateKonami() {
            document.body.classList.add('konami-active');

            // Spawn confetti
            const colors = ['#7a8a9a', '#a0a0a0', '#666', '#888', '#999', '#777', '#bbb'];
            for (let i = 0; i < 60; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + 'vw';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.animationDelay = (Math.random() * 1.5) + 's';
                piece.style.animationDuration = (2 + Math.random() * 2) + 's';
                piece.style.width = (6 + Math.random() * 8) + 'px';
                piece.style.height = (6 + Math.random() * 8) + 'px';
                piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
                document.body.appendChild(piece);
                setTimeout(() => piece.remove(), 5000);
            }

            // Remove rainbow after a bit
            setTimeout(() => document.body.classList.remove('konami-active'), 5000);

            // Show a secret message in terminal if open
            const termBody = document.getElementById('terminal-body');
            if (termBody && document.getElementById('terminal-overlay').classList.contains('active')) {
                addTerminalLine('');
                addTerminalLine('<span style="color: #999;">★ KONAMI CODE ACTIVATED ★</span>');
                addTerminalLine('<span style="color: #999;">You found the secret! Enjoy the rainbow.</span>');
                addTerminalLine('');
            }
        }

        // =============================================
        // SCROLL REVEAL ANIMATIONS
        // =============================================
        function initScrollReveals() {
            const revealEls = document.querySelectorAll('.scroll-reveal, .scroll-stagger');
            if (!revealEls.length) return;

            // Instantly reveal elements already in the viewport (above the fold)
            // to prevent the jarring translateY "jump" on page load
            revealEls.forEach(el => {
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight && rect.bottom > 0) {
                    el.style.transition = 'none';
                    el.classList.add('revealed');
                    // Re-enable transitions after paint so future scroll reveals still animate
                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => { el.style.transition = ''; });
                    });
                }
            });

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                    }
                });
            }, { threshold: 0.1 });

            revealEls.forEach(el => {
                if (!el.classList.contains('revealed')) {
                    observer.observe(el);
                }
            });
        }
        initScrollReveals();

        // =============================================
        // STATS BAR FILL + COUNTER ANIMATIONS
        // =============================================
        function initStatAnimations() {
            // Animated bar fills (IntersectionObserver — safe to init early)
            const bars = document.querySelectorAll('.stat-card-bar-fill[data-width]');
            if (bars.length) {
                const barObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.style.width = entry.target.dataset.width;
                            entry.target.classList.add('animated');
                            barObserver.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });
                bars.forEach(bar => barObserver.observe(bar));
            }
            // Counter animations for hero stats — wait for loader to finish
            function startCounters() {
                const counters = document.querySelectorAll('.hero-stat-value[data-count]');
                counters.forEach(el => {
                    const target = parseInt(el.dataset.count);
                    let current = 0;
                    const increment = Math.max(1, Math.floor(target / 30));
                    const timer = setInterval(() => {
                        current += increment;
                        if (current >= target) { current = target; clearInterval(timer); }
                        el.textContent = current;
                    }, 50);
                });
            }
            const loaderEl = document.getElementById('loader');
            if (loaderEl && loaderEl.classList.contains('hidden')) {
                startCounters();
            } else {
                document.addEventListener('loaderDone', startCounters, { once: true });
            }
        }
        initStatAnimations();

        // =============================================
        // 3D CARD TILT
        // =============================================
        function initTiltCards() {
            const tiltCards = document.querySelectorAll('.tilt-card');
            tiltCards.forEach(card => {
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    const rotateX = (y - centerY) / centerY * -8;
                    const rotateY = (x - centerX) / centerX * 8;

                    card.style.transform = 'perspective(800px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)';
                    card.style.setProperty('--shine-x', (x / rect.width * 100) + '%');
                    card.style.setProperty('--shine-y', (y / rect.height * 100) + '%');
                });

                card.addEventListener('mouseleave', () => {
                    card.style.transform = 'perspective(800px) rotateX(0) rotateY(0)';
                });
            });
        }
        initTiltCards();

        // =============================================
        // WEB QUIZ: HOW WELL DO YOU KNOW RYAN?
        // =============================================
        (function() {
            const overlay = document.getElementById('quiz-modal-overlay');
            const inner = document.getElementById('quiz-modal-inner');
            const closeBtn = document.getElementById('quiz-close');

            const allQuizQuestions = [
                { q: "What is Ryan's unweighted GPA?", options: ['3.85', '3.92', '3.98', '4.0'], answer: 2 },
                { q: "What is Ryan's Manifold Markets username?", options: ['@RyanMcComb', '@JeromeHPowell', '@de_bayes', '@PredictionRyan'], answer: 1 },
                { q: 'What congressional district does IL9CAST model?', options: ['Illinois 5th', 'Illinois 9th', 'Illinois 11th', 'Illinois 7th'], answer: 1 },
                { q: "What is Ryan's podcast called?", options: ['The Forecast', 'Project 2028', 'Swing State Pod', 'The Bayes Report'], answer: 1 },
                { q: 'What sport does Ryan photograph for Chicago Union?', options: ['Soccer', 'Lacrosse', 'Ultimate Frisbee', 'Rugby'], answer: 2 },
                { q: "What is Ryan's P2P lending project?", options: ['LoanLink', 'ManiFed', 'PeerFund', 'MicroLend'], answer: 1 },
                { q: "What is Ryan's GitHub username?", options: ['@ryanmccomb', '@bayes-dev', '@de-bayes', '@mccomb-ryan'], answer: 2 },
                { q: 'Which publications featured IL9CAST?', options: ['Chicago Tribune & Sun-Times', 'Capitol Fax, Evanston Roundtable & Daily Northwestern', "Crain's Chicago & Block Club", 'Politico & The Hill'], answer: 1 },
                { q: 'What short film did Ryan make?', options: ['Lake Effect', 'Cabin Life', 'North Shore', 'The Forecast'], answer: 1 },
                { q: "What is Ryan's graduation year?", options: ['2025', '2028', '2027', '2024'], answer: 1 },
                { q: 'What campaign is Ryan a finance lead for?', options: ['Casten for Congress', 'Biss for Congress', 'Schakowsky for Congress', 'Duckworth for Senate'], answer: 1 },
                { q: 'What side of VoteHub is Ryan a Student Fellow on?', options: ['Communications', 'Data Science', 'Policy Research', 'Campaign Strategy'], answer: 1 },
                { q: 'Where does Ryan work as a swim instructor?', options: ['YMCA', 'YWCA', 'Evanston Aquatics', 'Northwestern Pool'], answer: 1 },
                { q: "What is the name of Ryan's election model?", options: ['ForecastIL', 'IL9CAST', 'NinthDistrict', 'Prairie Poll'], answer: 1 },
                { q: "What programming language is Ryan's website primarily built with?", options: ['React', 'Plain HTML/CSS/JS', 'Next.js', 'Svelte'], answer: 1 },
                { q: "Which Twitter account follows Ryan's @bayes_pr?", options: ['@NateSilver538', '@umichvoter', '@redistrict', '@PollsterHQ'], answer: 1 },
                { q: "What bone did Ryan break as a kid?", options: ['Arm', 'Femur', 'Collarbone', 'Wrist'], answer: 1 },
                { q: "What nationality is Ryan besides American?", options: ['British', 'Canadian', 'Australian', 'Irish'], answer: 1 },
                { q: "What position did Ryan play in hockey?", options: ['Forward', 'Defense', 'Goalie', 'Center'], answer: 2 },
                { q: "Which social media did Ryan's post go viral on?", options: ['Twitter', 'Instagram', 'Threads', 'TikTok'], answer: 2 },
                { q: "What did the goalie Ryan backed up on his club team go on to play for?", options: ['U16 national team', 'U18 national team', 'OHL team', 'NCAA Division I'], answer: 1 },
                { q: "What famous Canadian building did one of Ryan's ancestors own?", options: ['Rideau Hall', '24 Sussex Drive', 'Stornoway', 'Harrington Lake'], answer: 1 },
            ];

            let quizState = null;

            function getRating(s) {
                if (s <= 2) return { text: 'Complete stranger vibes.', color: '#888' };
                if (s <= 4) return { text: 'Casual acquaintance.', color: '#7a8a9a' };
                if (s <= 6) return { text: 'You know some things!', color: '#dcdcaa' };
                if (s <= 8) return { text: 'Close friend energy.', color: '#aaa' };
                if (s === 9) return { text: 'Basically best friends.', color: '#999' };
                return { text: 'You ARE Ryan McComb.', color: '#c586c0' };
            }

            function renderNameScreen() {
                const taken = localStorage.getItem('webquiz_taken');
                if (taken) {
                    const prevScore = localStorage.getItem('webquiz_high_score') || '?';
                    inner.innerHTML = '<div class="quiz-header"><h2>HOW WELL DO YOU KNOW RYAN?</h2></div>' +
                        '<div class="quiz-name-screen">' +
                        '<p style="color:#7a8a9a;font-family:VT323,monospace;font-size:1.2rem;">You already took the quiz!</p>' +
                        '<p>Your score: <strong>' + prevScore + '/10</strong></p>' +
                        '<p style="font-size:0.8rem;color:var(--text-light);">One attempt only — no retries.</p>' +
                        '</div>';
                    return;
                }
                inner.innerHTML = '<div class="quiz-header"><h2>HOW WELL DO YOU KNOW RYAN?</h2></div>' +
                    '<div class="quiz-name-screen">' +
                    '<p>10 questions. One attempt. No going back.<br>Think you know Ryan? Prove it.</p>' +
                    '<input type="text" class="quiz-name-input" id="quiz-name" placeholder="Enter your name" maxlength="20" autocomplete="off">' +
                    '<br><button class="quiz-start-btn" id="quiz-start-btn" disabled>START</button>' +
                    '</div>';

                var nameInput = document.getElementById('quiz-name');
                var startBtn = document.getElementById('quiz-start-btn');
                nameInput.addEventListener('input', function() {
                    startBtn.disabled = !nameInput.value.trim();
                });
                nameInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && nameInput.value.trim()) startQuiz(nameInput.value.trim());
                });
                startBtn.addEventListener('click', function() {
                    if (nameInput.value.trim()) startQuiz(nameInput.value.trim());
                });
                setTimeout(function() { nameInput.focus(); }, 100);
            }

            function startQuiz(playerName) {
                var shuffled = allQuizQuestions.slice().sort(function() { return Math.random() - 0.5; });
                quizState = {
                    name: playerName,
                    questions: shuffled.slice(0, 10),
                    current: 0,
                    score: 0
                };
                renderQuestion();
            }

            function renderQuestion() {
                var s = quizState;
                var q = s.questions[s.current];
                var labels = ['A', 'B', 'C', 'D'];
                var optionsHtml = q.options.map(function(opt, i) {
                    return '<button class="quiz-option" data-idx="' + i + '">' +
                        '<span class="quiz-option-label">' + labels[i] + '.</span> ' + opt +
                        '</button>';
                }).join('');

                inner.innerHTML = '<div class="quiz-header"><h2>HOW WELL DO YOU KNOW RYAN?</h2></div>' +
                    '<div class="quiz-progress">' +
                    '<div class="quiz-progress-bar"><div class="quiz-progress-fill" style="width:' + (s.current / 10 * 100) + '%"></div></div>' +
                    '<span class="quiz-progress-text">' + (s.current + 1) + '/10</span>' +
                    '</div>' +
                    '<div class="quiz-score-display">Score: ' + s.score + '</div>' +
                    '<div class="quiz-question">' + q.q + '</div>' +
                    '<div class="quiz-options">' + optionsHtml + '</div>';

                var btns = inner.querySelectorAll('.quiz-option');
                btns.forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        handleAnswer(parseInt(btn.dataset.idx));
                    });
                });
            }

            function handleAnswer(idx) {
                var s = quizState;
                var q = s.questions[s.current];
                var correct = idx === q.answer;
                if (correct) s.score++;

                var btns = inner.querySelectorAll('.quiz-option');
                btns.forEach(function(btn, i) {
                    btn.classList.add('disabled');
                    if (i === q.answer) btn.classList.add('correct');
                    else if (i === idx && !correct) btn.classList.add('wrong');
                    else btn.classList.add('dimmed');
                });

                setTimeout(function() {
                    s.current++;
                    if (s.current >= 10) {
                        finishQuiz();
                    } else {
                        renderQuestion();
                    }
                }, 1000);
            }

            function finishQuiz() {
                var s = quizState;
                localStorage.setItem('webquiz_taken', 'true');
                localStorage.setItem('webquiz_high_score', s.score.toString());
                var lb = JSON.parse(localStorage.getItem('webquiz_leaderboard') || '[]');
                lb.push({ name: s.name.substring(0, 20), score: s.score, date: new Date().toLocaleDateString() });
                lb.sort(function(a, b) { return b.score - a.score; });
                lb = lb.slice(0, 50);
                localStorage.setItem('webquiz_leaderboard', JSON.stringify(lb));

                var rating = getRating(s.score);
                var lbHtml = '';
                if (lb.length > 0) {
                    lbHtml = '<div class="quiz-leaderboard"><h3>LEADERBOARD</h3>';
                    var top10 = lb.slice(0, 10);
                    top10.forEach(function(entry, i) {
                        var rank = i === 0 ? '1st' : i === 1 ? '2nd' : i === 2 ? '3rd' : (i + 1) + 'th';
                        var rankClass = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '';
                        var isYou = entry.name === s.name.substring(0, 20) && entry.score === s.score;
                        lbHtml += '<div class="quiz-lb-entry' + (isYou ? ' you' : '') + '">' +
                            '<span class="quiz-lb-rank ' + rankClass + '">' + rank + '</span>' +
                            '<span class="quiz-lb-name">' + entry.name + (isYou ? ' (you)' : '') + '</span>' +
                            '<span class="quiz-lb-score">' + entry.score + '/10</span></div>';
                    });
                    lbHtml += '</div>';
                }

                inner.innerHTML = '<div class="quiz-header"><h2>QUIZ COMPLETE</h2></div>' +
                    '<div class="quiz-results">' +
                    '<div class="quiz-results-score">' + s.score + '/10</div>' +
                    '<div class="quiz-results-rating" style="color:' + rating.color + '">' + rating.text + '</div>' +
                    '<div class="quiz-results-name">Recorded as: ' + s.name + '</div>' +
                    lbHtml +
                    '<p class="quiz-footer-note">One attempt only — no retries!</p>' +
                    '</div>';
            }

            window.openWebQuiz = function() {
                overlay.classList.add('active');
                renderNameScreen();
            };

            closeBtn.addEventListener('click', function() {
                if (quizState && quizState.current > 0 && quizState.current < 10) {
                    localStorage.setItem('webquiz_taken', 'true');
                    localStorage.setItem('webquiz_high_score', quizState.score.toString());
                    var lb = JSON.parse(localStorage.getItem('webquiz_leaderboard') || '[]');
                    lb.push({ name: quizState.name.substring(0, 20), score: quizState.score, date: new Date().toLocaleDateString() });
                    lb.sort(function(a, b) { return b.score - a.score; });
                    localStorage.setItem('webquiz_leaderboard', JSON.stringify(lb.slice(0, 50)));
                }
                overlay.classList.remove('active');
                quizState = null;
            });

            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) closeBtn.click();
            });
        })();

        // =============================================
        // WEB TWO TRUTHS AND A LIE
        // =============================================
        (function() {
            var overlay = document.getElementById('truths-modal-overlay');
            var inner = document.getElementById('truths-modal-inner');
            var closeBtn = document.getElementById('truths-close');

            var allTruthRounds = [
                {
                    statements: [
                        { text: 'Ryan is a US-Canadian dual citizen', isLie: false },
                        { text: 'Ryan ran a sub-20-minute 5k', isLie: false },
                        { text: 'Ryan plays varsity basketball at ETHS', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: '@umichvoter follows Ryan (@bayes_pr) on Twitter', isLie: false },
                        { text: 'Ryan broke his femur as a kid and had a body cast for 3 months', isLie: false },
                        { text: 'Ryan interned at FiveThirtyEight in 2025', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan had a tweet go viral on Threads (500k+ views)', isLie: false },
                        { text: 'This entire website is a huge OSINT liability', isLie: false },
                        { text: 'Ryan is editor-in-chief of The Evanstonian', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "Ryan's club team starting goalie went on to play for the U18 national team", isLie: false },
                        { text: "Ryan's mom knew Justin Trudeau as a kid", isLie: false },
                        { text: 'Ryan teaches coding classes at Northwestern', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan built an election forecasting model that got press coverage', isLie: false },
                        { text: 'Ryan is a US-Canadian dual citizen', isLie: false },
                        { text: 'Ryan has been to every Canadian province', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan photographs professional ultimate frisbee games', isLie: false },
                        { text: 'Ryan ran a sub-20-minute 5k', isLie: false },
                        { text: 'Ryan has been to every US state', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan had a tweet go viral on Threads (500k+ views)', isLie: false },
                        { text: 'Ryan works as a swim instructor', isLie: false },
                        { text: 'Ryan runs a daily political newsletter with 10k subscribers', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "Ryan's club team starting goalie went on to play for the U18 national team", isLie: false },
                        { text: 'Ryan built a P2P lending project called ManiFed', isLie: false },
                        { text: 'Ryan placed top 3 at a national hackathon', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "Ryan's mom knew Justin Trudeau as a kid", isLie: false },
                        { text: 'Ryan is a finance lead for a congressional campaign', isLie: false },
                        { text: 'Ryan is the student body president of ETHS', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan is a US-Canadian dual citizen', isLie: false },
                        { text: 'Ryan made a short film called Cabin Life', isLie: false },
                        { text: 'Ryan has published a book on election modeling', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "Ryan's podcast is called Project 2028", isLie: false },
                        { text: 'Ryan is a Student Fellow on the Data Science side of VoteHub', isLie: false },
                        { text: 'Ryan founded a startup that was accepted into Y Combinator', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: 'Ryan built a website that has a working terminal with games', isLie: false },
                        { text: 'Ryan has a GPA above 3.9', isLie: false },
                        { text: 'Ryan spent a summer studying abroad in Tokyo', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "Ryan's IL9CAST model was featured in Capitol Fax", isLie: false },
                        { text: 'Ryan made a short film called Cabin Life', isLie: false },
                        { text: 'Ryan was a varsity swimmer who competed at state', isLie: true },
                    ]
                },
                {
                    statements: [
                        { text: "A distant grandfather of Ryan's once owned 24 Sussex, the Canadian PM's residence", isLie: false },
                        { text: 'Ryan works as a swim instructor', isLie: false },
                        { text: 'Ryan has been to every Canadian province', isLie: true },
                    ]
                },
            ];

            var truthsState = null;

            function getRating(s, total) {
                var pct = s / total;
                if (pct <= 0.15) return { text: 'You believed everything!', color: '#888' };
                if (pct <= 0.4) return { text: 'Getting warmer...', color: '#7a8a9a' };
                if (pct <= 0.7) return { text: 'Decent BS detector.', color: '#dcdcaa' };
                if (pct <= 0.85) return { text: 'Very perceptive!', color: '#999' };
                return { text: 'Human lie detector!', color: '#c586c0' };
            }

            function startGame() {
                var shuffled = allTruthRounds.slice().sort(function() { return Math.random() - 0.5; }).slice(0, 7);
                var rounds = shuffled.map(function(r) {
                    return { statements: r.statements.slice().sort(function() { return Math.random() - 0.5; }) };
                });
                truthsState = { rounds: rounds, current: 0, score: 0, streak: 0, bestStreak: 0 };
                renderRound();
            }

            function renderRound() {
                var s = truthsState;
                var round = s.rounds[s.current];
                var cardsHtml = round.statements.map(function(stmt, i) {
                    return '<div class="truth-card" data-idx="' + i + '">' + stmt.text + '</div>';
                }).join('');

                inner.innerHTML = '<div class="truths-header"><h2>TWO TRUTHS &amp; A LIE</h2></div>' +
                    '<div class="quiz-progress">' +
                    '<div class="quiz-progress-bar"><div class="quiz-progress-fill" style="width:' + (s.current / 7 * 100) + '%"></div></div>' +
                    '<span class="quiz-progress-text">' + (s.current + 1) + '/7</span>' +
                    '</div>' +
                    '<div class="quiz-score-display">Score: ' + s.score + '  |  Streak: ' + s.streak + '</div>' +
                    '<div class="truths-instruction">Pick the lie.</div>' +
                    '<div class="truths-statements">' + cardsHtml + '</div>' +
                    '<div class="truths-result-line" id="truths-result-line"></div>';

                var cards = inner.querySelectorAll('.truth-card');
                cards.forEach(function(card) {
                    card.addEventListener('click', function() {
                        handleTruthPick(parseInt(card.dataset.idx));
                    });
                });
            }

            function handleTruthPick(idx) {
                var s = truthsState;
                var round = s.rounds[s.current];
                var picked = round.statements[idx];
                var correct = picked.isLie;
                if (correct) {
                    s.score++;
                    s.streak++;
                    if (s.streak > s.bestStreak) s.bestStreak = s.streak;
                } else {
                    s.streak = 0;
                }

                var cards = inner.querySelectorAll('.truth-card');
                var resultLine = document.getElementById('truths-result-line');
                cards.forEach(function(card, i) {
                    card.classList.add('disabled');
                    var stmt = round.statements[i];
                    if (stmt.isLie) {
                        card.classList.add('is-lie');
                        card.innerHTML += '<span class="truth-label" style="color:#888">LIE</span>';
                    } else {
                        card.classList.add('is-truth');
                        card.innerHTML += '<span class="truth-label" style="color:#999">TRUTH</span>';
                    }
                });

                if (correct) {
                    resultLine.innerHTML = '<span style="color:#999">Correct! You spotted the lie.</span>';
                } else {
                    resultLine.innerHTML = '<span style="color:#888">Wrong — that one was true!</span>';
                }

                setTimeout(function() {
                    s.current++;
                    if (s.current >= 7) {
                        finishTruths();
                    } else {
                        renderRound();
                    }
                }, 1400);
            }

            function finishTruths() {
                var s = truthsState;
                var rating = getRating(s.score, 7);
                var prevHigh = parseInt(localStorage.getItem('web2truths_high_score') || '0');
                var isNewHigh = s.score > prevHigh;
                if (isNewHigh) localStorage.setItem('web2truths_high_score', s.score.toString());

                var highHtml = isNewHigh
                    ? '<div class="truths-high-score" style="color:#c586c0">NEW HIGH SCORE!</div>'
                    : '<div class="truths-high-score" style="color:var(--text-light)">High score: ' + prevHigh + '/7</div>';

                inner.innerHTML = '<div class="truths-header"><h2>GAME COMPLETE</h2></div>' +
                    '<div class="truths-results">' +
                    '<div class="truths-results-score">' + s.score + '/7</div>' +
                    '<div class="truths-results-rating" style="color:' + rating.color + '">' + rating.text + '</div>' +
                    '<div class="truths-results-streak">Best streak: ' + s.bestStreak + '</div>' +
                    highHtml +
                    '<button class="truths-play-again" id="truths-retry">PLAY AGAIN</button>' +
                    '</div>';

                document.getElementById('truths-retry').addEventListener('click', startGame);
            }

            window.openWebTruths = function() {
                overlay.classList.add('active');
                startGame();
            };

            closeBtn.addEventListener('click', function() {
                overlay.classList.remove('active');
                truthsState = null;
            });

            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) closeBtn.click();
            });
        })();

        // =============================================
        // ANALYTICS TRACKING
        // =============================================
        (function() {
            fetch('/api/track', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ event: 'pageview', value: 'home' })
            }).catch(() => {});
        })();

        // Track commands in executeCommand
        const _origExecute = executeCommand;
        executeCommand = function(cmd) {
            const c = cmd.trim().toLowerCase();
            if (c && c.startsWith('/')) {
                fetch('/api/track', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ event: 'command', value: c.split(' ')[0] })
                }).catch(() => {});
                // Track game plays
                if (['/snake', '/dino', '/tetris', '/wordle', '/type', '/quiz', '/2truths'].includes(c)) {
                    fetch('/api/track', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ event: 'game', value: c })
                    }).catch(() => {});
                }
            }
            return _origExecute(cmd);
        };

    </script>

    <script src="scroll-hide.js"></script>
</body>
</html>
