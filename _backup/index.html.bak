<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ryan McComb</title>
    <meta name="description" content="Ryan McComb — student, data analyst, forecaster, and writer from Evanston, IL.">
    <meta name="author" content="Ryan McComb">
    <meta property="og:title" content="Ryan McComb">
    <meta property="og:description" content="Data, politics, and forecasting.">
    <meta property="og:type" content="website">
    <link rel="icon" href="favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="features.css">
</head>
<body>
    <!-- LOADER -->
    <div id="loader" class="loader">
        <p class="loader-url"><span>r</span><span>j</span><span>m</span><span>c</span><span>c</span><span>o</span><span>m</span><span>b</span><span>.</span><span>x</span><span>y</span><span>z</span></p>
    </div>

    <!-- FILM GRAIN -->
    <div class="grain-overlay"></div>

    <!-- PHYSICS VISUALIZATION -->
    <canvas id="physics-canvas" style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:99998;display:none;"></canvas>
    <div id="physics-hud" style="display:none;position:fixed;bottom:20px;left:20px;z-index:99998;pointer-events:none;font-family:'VT323',monospace;font-size:14px;line-height:1.6;color:#00ff88;background:rgba(0,0,0,0.85);padding:12px 16px;border:1px solid #00ff88;backdrop-filter:blur(4px);min-width:260px;"></div>

    <!-- SITE CONTENT -->
    <div id="site-content">

        <!-- FIVEY FOX MASCOT -->
        <div class="mascot-corner" id="mascot-corner" style="position:fixed;bottom:80px;right:20px;">
            <img src="538mascot.webp" alt="Fivey Fox" class="mascot-img" style="width:150px;cursor:grab;user-select:none;transition:transform 0.2s ease;filter:drop-shadow(2px 4px 6px rgba(0,0,0,0.15));">
            <div class="mascot-tooltip">
                <p>My name is Fivey Fox! I was the mascot for 538 before Disney killed me. I sparked Ryan's interest in politics and prediction markets. Check out his <a href="#projects" onclick="event.preventDefault();expandCard('projects')">projects</a>!</p>
                <p style="margin-top:0.5rem;font-size:0.7rem;opacity:0.7">Grab and throw me! I have real physics now.</p>
                <p class="fivey-bounce-counter" id="fivey-bounce-counter" style="margin-top:0.4rem;font-size:0.65rem;opacity:0;transition:opacity 0.3s;font-variant-numeric:tabular-nums;"></p>
            </div>
        </div>

        <!-- TERMINAL TOGGLE BUTTON (hidden) -->
        <div class="terminal-button" onclick="openTerminal()" style="position:fixed;bottom:20px;right:20px;width:40px;height:40px;display:none;align-items:center;justify-content:center;background:var(--bg-card);border:1px solid var(--border-color);border-radius:50%;cursor:pointer;z-index:999;font-size:0.85rem;color:var(--text-secondary);transition:all 0.2s ease;box-shadow:0 2px 8px rgba(0,0,0,0.06);" title="Open Terminal">&#9000;</div>


        <!-- EDITORIAL LAYOUT -->
        <div class="editorial-page">
            <header class="editorial-hero" id="editorial-hero">
                <div class="hero-glow" id="hero-glow"></div>
                <div class="editorial-hero-content">
                    <div class="editorial-hero-text">
                        <h1 class="editorial-name">RYAN McCOMB</h1>
                        <div class="editorial-tagline" id="editorial-tagline"></div>
                    </div>
                    <div class="editorial-hero-svg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="124" height="46" viewBox="0 0 124 46">
                            <rect class="hero-svg-bg" x="0" y="0" width="124" height="46" rx="4" fill="transparent"/>
                            <g fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" class="hero-svg-icon">
                                <line x1="41" y1="12" x2="83" y2="12"/>
                                <path d="M62 17 L44 33 M62 17 L80 33"/>
                            </g>
                        </svg>
                    </div>
                </div>
            </header>
            <main class="editorial-body">
                <p class="scroll-reveal">I'm <strong>Ryan McComb</strong>, a student at <a href="#experience" onclick="event.preventDefault();expandCard('experience')">Evanston Township High School</a> interested in <strong>data</strong>, <strong>prediction markets</strong>, <strong>politics</strong>, and the web. I like making things people can use and forming beliefs based on evidence.</p>

                <p class="scroll-reveal">I built <a href="https://il9.org" target="_blank"><strong>IL9.org</strong></a>, an open-source <a href="#projects" onclick="event.preventDefault();expandCard('projects')">political forecasting project</a>. I'm also a <strong>Student Fellow</strong> at <a href="#experience" onclick="event.preventDefault();expandCard('experience')">VoteHub</a> doing race-call work and election modeling, and a <strong>Volunteer Finance Lead</strong> for the <a href="#experience" onclick="event.preventDefault();expandCard('experience')">Biss congressional campaign</a>.</p>

                <p class="scroll-reveal">I trade on play-money <a href="#forecasting" onclick="event.preventDefault();expandCard('forecasting')">prediction markets</a>, <a href="#blog" onclick="event.preventDefault();expandCard('blog')">write essays</a> on politics and data, and shoot <a href="#photos" onclick="event.preventDefault();expandCard('photos')">film photography</a>. My work has been featured in the <em>Evanston Roundtable</em>, the <em>Daily Northwestern</em>, and <em>Capitol Fax</em>.</p>

                <p class="scroll-reveal" style="margin-top: 1.5rem;"><a href="resume.html" style="font-family: var(--font-sans); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none; border: 1px solid #2244cc; padding: 0.5rem 1.2rem;">View Resume &rarr;</a></p>
            </main>

            <!-- Footer -->
            <footer class="editorial-footer">
                <nav class="editorial-sitemap">
                    <a href="#experience" onclick="event.preventDefault();expandCard('experience')">Work</a>
                    <a href="#projects" onclick="event.preventDefault();expandCard('projects')">Projects</a>
                    <a href="#blog" onclick="event.preventDefault();expandCard('blog')">Writing</a>
                    <a href="#photos" onclick="event.preventDefault();expandCard('photos')">Photos</a>
                    <a href="#forecasting" onclick="event.preventDefault();expandCard('forecasting')">Forecasting</a>
                    <a href="#hottakes" onclick="event.preventDefault();expandCard('hottakes')">Hot Takes</a>
                    <a href="#countdowns" onclick="event.preventDefault();expandCard('countdowns')">Countdowns</a>
                    <a href="#contact" onclick="event.preventDefault();expandCard('contact')">Contact</a>
                    <a href="resume.html">Resume</a>
                </nav>
                <div class="editorial-footer-bottom">
                    <span>&copy; 2026 Ryan McComb &middot; Evanston, IL</span>
                    <button class="minimal-theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="Toggle theme">&#9790;</button>
                </div>
                <button class="terminal-open-btn" onclick="openTerminal()">&#9000; Open Terminal</button>
                <button class="terminal-open-btn physics-toggle-btn" id="physics-toggle-btn" onclick="window.togglePhysicsViz && window.togglePhysicsViz()" style="margin-left:0.5rem;">&#9881; Physics Mode</button>
            </footer>
        </div>

        <!-- EXPAND OVERLAY -->
        <div id="expand-overlay" class="expand-overlay">
            <button class="expand-back" onclick="collapseCard()">&larr; Back</button>
            <div class="expand-content" id="expand-content"></div>
        </div>
    </div>


    <!-- DESKTOP OS MODE -->
    <div class="desktop-overlay" id="desktop-overlay">
        <div class="desktop-area" id="desktop-area">
            <div class="desktop-icons" id="desktop-icons"></div>
        </div>
        <div class="start-menu" id="start-menu"></div>
        <div class="desktop-taskbar" id="desktop-taskbar">
            <div class="taskbar-start" id="taskbar-start">RM</div>
            <div class="taskbar-divider"></div>
            <div class="taskbar-windows" id="taskbar-windows"></div>
            <div class="taskbar-clock" id="taskbar-clock"></div>
        </div>
    </div>

    <!-- TERMINAL OVERLAY -->
    <div class="terminal-overlay" id="terminal-overlay">
        <canvas id="terminal-grid"></canvas>
        <div class="terminal-window">
            <div class="terminal-header">
                <div class="terminal-controls">
                    <button class="terminal-btn close" onclick="closeTerminal()"></button>
                    <button class="terminal-btn minimize"></button>
                    <button class="terminal-btn maximize"></button>
                </div>
                <span class="terminal-title">terminal &mdash; ryan@mccomb</span>
            </div>
            <div class="terminal-body" id="terminal-body">
                <pre class="ascii-art" style="margin-bottom: 1rem;">
  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;    &#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;    &#9608;&#9608;     &#9608;&#9608;&#9608;    &#9608;&#9608;&#9608; &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;    &#9608;&#9608;&#9608; &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;
  &#9608;&#9608;   &#9608;&#9608;  &#9608;&#9608;  &#9608;&#9608;  &#9608;&#9608;   &#9608;&#9608; &#9608;&#9608;&#9608;&#9608;   &#9608;&#9608;     &#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608; &#9608;&#9608;      &#9608;&#9608;      &#9608;&#9608;    &#9608;&#9608; &#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608; &#9608;&#9608;   &#9608;&#9608;
  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;    &#9608;&#9608;&#9608;&#9608;   &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;&#9608; &#9608;&#9608; &#9608;&#9608;  &#9608;&#9608;     &#9608;&#9608; &#9608;&#9608;&#9608;&#9608; &#9608;&#9608; &#9608;&#9608;      &#9608;&#9608;      &#9608;&#9608;    &#9608;&#9608; &#9608;&#9608; &#9608;&#9608;&#9608;&#9608; &#9608;&#9608; &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;
  &#9608;&#9608;   &#9608;&#9608;    &#9608;&#9608;    &#9608;&#9608;   &#9608;&#9608; &#9608;&#9608;  &#9608;&#9608; &#9608;&#9608;     &#9608;&#9608;  &#9608;&#9608;  &#9608;&#9608; &#9608;&#9608;      &#9608;&#9608;      &#9608;&#9608;    &#9608;&#9608; &#9608;&#9608;  &#9608;&#9608;  &#9608;&#9608; &#9608;&#9608;   &#9608;&#9608;
  &#9608;&#9608;   &#9608;&#9608;    &#9608;&#9608;    &#9608;&#9608;   &#9608;&#9608; &#9608;&#9608;   &#9608;&#9608;&#9608;&#9608;     &#9608;&#9608;      &#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;  &#9608;&#9608;      &#9608;&#9608; &#9608;&#9608;&#9608;&#9608;&#9608;&#9608;
                </pre>
                <div class="terminal-line" style="margin-bottom: 0.5rem;">&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;&#9473;</div>
                <div class="terminal-line" style="margin-bottom: 1rem;">Welcome to Ryan McComb's interactive terminal. Type <span class="terminal-command">/info</span> to see available commands.</div>
                <div class="terminal-input-line">
                    <span class="terminal-prompt">ryan@mccomb:~$</span>
                    <div class="terminal-input-wrap">
                        <span class="terminal-autocomplete" id="terminal-autocomplete"></span>
                        <input type="text" class="terminal-input" id="terminal-input" autocomplete="off" spellcheck="false">
                    </div>
                    <div class="terminal-suggestions" id="terminal-suggestions"></div>
                </div>
            </div>
            <div class="terminal-resize-handle"></div>
        </div>
    </div>

    <!-- QUIZ MODAL -->
    <div class="quiz-modal-overlay" id="quiz-modal-overlay">
        <div class="quiz-modal-inner" id="quiz-modal-inner">
            <button class="quiz-close" id="quiz-close">&times;</button>
        </div>
    </div>

    <!-- TWO TRUTHS MODAL -->
    <div class="truths-modal-overlay" id="truths-modal-overlay">
        <div class="truths-modal-inner" id="truths-modal-inner">
            <button class="truths-close" id="truths-close">&times;</button>
        </div>
    </div>

    <script>
        // MOUSE-REACTIVE HERO GLOW
        (function initHeroGlow() {
            const hero = document.getElementById('editorial-hero');
            const glow = document.getElementById('hero-glow');
            if (!hero || !glow) return;

            hero.addEventListener('mousemove', e => {
                const rect = hero.getBoundingClientRect();
                const x = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);
                const y = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);
                glow.style.setProperty('--mouse-x', x + '%');
                glow.style.setProperty('--mouse-y', y + '%');
            });
        })();
    </script>
    <script>
        // THEME TOGGLE — light (white) is default
        function toggleTheme() {
            const html = document.documentElement;
            const isDark = html.getAttribute('data-theme') === 'dark';
            if (isDark) {
                html.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
                document.getElementById('theme-toggle').textContent = '\u263E';
            } else {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
                document.getElementById('theme-toggle').textContent = '\u2600';
            }
        }
        (function() {
            const saved = localStorage.getItem('theme');
            if (saved === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                var btn = document.getElementById('theme-toggle');
                if (btn) btn.textContent = '\u2600';
            }
        })();
    </script>
    <script>
        // HAMBURGER MENU
        function toggleNav() {
            document.querySelector('.hamburger').classList.toggle('active');
            document.querySelector('.nav-links').classList.toggle('mobile-open');
        }

        // Close menu when clicking a link
        document.querySelectorAll('.nav-dropdown-menu a').forEach(link => {
            link.addEventListener('click', () => {
                document.querySelector('.hamburger').classList.remove('active');
                document.querySelector('.nav-links').classList.remove('mobile-open');
            });
        });

        const loader = document.getElementById('loader');
        const siteContent = document.getElementById('site-content');

        function finishLoader() {
            loader.classList.add('hidden');
            loader.addEventListener('transitionend', function onEnd() {
                loader.removeEventListener('transitionend', onEnd);
                siteContent.classList.add('visible');
                document.dispatchEvent(new Event('loaderDone'));
            }, { once: true });
            setTimeout(() => {
                if (!siteContent.classList.contains('visible')) {
                    siteContent.classList.add('visible');
                    document.dispatchEvent(new Event('loaderDone'));
                }
            }, 700);
            setTimeout(showFivey, 2000);
        }

        // Check if page was refreshed or is a new visit
        const perfData = performance.getEntriesByType?.('navigation')?.[0];
        const isRefresh = perfData?.type === 'reload';
        const hasLoaded = sessionStorage.getItem('hasLoaded');

        if (hasLoaded && !isRefresh) {
            loader.classList.add('hidden');
            siteContent.classList.add('visible');
            document.dispatchEvent(new Event('loaderDone'));
            setTimeout(showFivey, 2000);
        } else {
            // Show the URL animation for 5 seconds then fade out
            setTimeout(finishLoader, 5000);
            sessionStorage.setItem('hasLoaded', 'true');
        }

        // Fivey Fox delayed entrance (stickerSlap animation)
        function showFivey() {
            const mascot = document.getElementById('mascot-corner');
            if (mascot) {
                mascot.classList.add('slap-in');
            }
        }

        // === LANDING PAGE ENHANCEMENTS ===

        // 1. Collaborative editing animation — multiple cursors editing the tagline
        // Character-by-character typing, selection expansion, strikethrough, bold highlight
        (function initCollabTagline() {
            var el = document.getElementById('editorial-tagline');
            if (!el) return;

            var users = {
                ryan:  { name: 'Ryan',  c: '#4285f4', bg: 'rgba(66,133,244,0.3)' },
                nate:  { name: 'Nate',  c: '#0f9d58', bg: 'rgba(15,157,88,0.3)' },
                galen: { name: 'Galen', c: '#db4437', bg: 'rgba(219,68,55,0.3)' }
            };

            // Mutable animation state
            var text = '';
            var cursors = [];
            var selections = [];
            var strikes = [];
            var bolds = [];
            var fading = [];
            var boldHighlight = false;

            function cur(id) {
                for (var i = 0; i < cursors.length; i++) {
                    if (cursors[i].id === id) return cursors[i];
                }
                return null;
            }

            function render() {
                var h = '';
                for (var i = 0; i <= text.length; i++) {
                    for (var ci = 0; ci < cursors.length; ci++) {
                        var c = cursors[ci];
                        if (c.pos === i) {
                            var u = users[c.id];
                            var f = fading.indexOf(c.id) >= 0 ? ' fading' : '';
                            h += '<span class="collab-cursor' + f + '" style="--c:' + u.c + '">'
                               + '<span class="collab-cursor-flag">' + u.name + '</span></span>';
                        }
                    }
                    if (i >= text.length) break;
                    var ch = text[i];
                    var cls = 'collab-char';
                    var sty = '';
                    for (var si = 0; si < selections.length; si++) {
                        var sel = selections[si];
                        if (i >= sel.start && i < sel.end) {
                            cls += ' collab-selected';
                            sty += '--sc:' + users[sel.id].bg + ';';
                        }
                    }
                    for (var ki = 0; ki < strikes.length; ki++) {
                        var st = strikes[ki];
                        if (i >= st.start && i < st.end) {
                            cls += ' collab-strike';
                            sty += '--kc:' + users[st.id].c + ';';
                        }
                    }
                    for (var bi = 0; bi < bolds.length; bi++) {
                        var b = bolds[bi];
                        if (i >= b.start && i < b.end) {
                            cls += ' collab-bold';
                            if (boldHighlight) cls += ' collab-bold-highlight';
                        }
                    }
                    var d = ch === ' ' ? '&nbsp;' : ch;
                    h += '<span class="' + cls + '"' + (sty ? ' style="' + sty + '"' : '') + '>' + d + '</span>';
                }
                el.innerHTML = h;
            }

            // Timeline builder
            var timeline = [];
            var t = 0;
            function after(ms, fn) { t += ms; timeline.push({ t: t, fn: fn }); }

            // === Phase 1: Text appears, cursors arrive one by one ===
            after(0, function() { text = 'Data, numbers, and predictions.'; render(); });
            after(600, function() { cursors.push({ id: 'nate', pos: 13 }); render(); });
            after(250, function() { cursors.push({ id: 'galen', pos: 31 }); render(); });
            after(250, function() { cursors.push({ id: 'ryan', pos: 0 }); render(); });

            // === Phase 2: Nate selects "numbers" backward (pos 12→6) ===
            after(800, function() {
                selections = [{ id: 'nate', start: 12, end: 13 }];
                cur('nate').pos = 12;
                render();
            });
            (function() {
                for (var p = 11; p >= 6; p--) {
                    (function(pos) {
                        after(55, function() {
                            selections[0].start = pos;
                            cur('nate').pos = pos;
                            render();
                        });
                    })(p);
                }
            })();

            // === Phase 3: Nate types "politics" (first char replaces selection) ===
            (function() {
                var word = 'politics';
                after(350, function() {
                    // First keystroke replaces the selected "numbers"
                    text = text.substring(0, 6) + word[0] + text.substring(13);
                    selections = [];
                    cur('nate').pos = 7;
                    cur('galen').pos = 25;
                    render();
                });
                for (var i = 1; i < word.length; i++) {
                    (function(idx, ch) {
                        after(95, function() {
                            var ins = 6 + idx;
                            text = text.substring(0, ins) + ch + text.substring(ins);
                            cur('nate').pos = ins + 1;
                            cur('galen').pos += 1;
                            render();
                        });
                    })(i, word[i]);
                }
            })();
            // Result: "Data, politics, and predictions." | nate@14 galen@32 ryan@0

            // === Phase 4: Pause, Ryan drifts cursor to pos 6 ===
            after(700, function() { cur('ryan').pos = 6; render(); });

            // === Phase 5: Galen selects "predictions" backward (pos 30→20) ===
            after(600, function() { cur('galen').pos = 31; render(); });
            after(350, function() {
                selections = [{ id: 'galen', start: 30, end: 31 }];
                cur('galen').pos = 30;
                render();
            });
            (function() {
                for (var p = 29; p >= 20; p--) {
                    (function(pos) {
                        after(50, function() {
                            selections[0].start = pos;
                            cur('galen').pos = pos;
                            render();
                        });
                    })(p);
                }
            })();

            // === Phase 6: Galen applies strikethrough ===
            after(400, function() {
                strikes = [{ id: 'galen', start: 20, end: 31 }];
                selections = [];
                cur('galen').pos = 20;
                render();
            });

            // === Phase 7: Galen types "forecasting" (replaces struck text) ===
            (function() {
                var word = 'forecasting';
                after(900, function() {
                    text = text.substring(0, 20) + word[0] + text.substring(31);
                    strikes = [];
                    cur('galen').pos = 21;
                    render();
                });
                for (var i = 1; i < word.length; i++) {
                    (function(idx, ch) {
                        after(80, function() {
                            var ins = 20 + idx;
                            text = text.substring(0, ins) + ch + text.substring(ins);
                            cur('galen').pos = ins + 1;
                            render();
                        });
                    })(i, word[i]);
                }
            })();
            // Result: "Data, politics, and forecasting." | galen@31

            // === Phase 8: Ryan selects "politics" forward (pos 6→14) ===
            after(900, function() {
                cur('nate').pos = 32;
                cur('galen').pos = 32;
                render();
            });
            after(500, function() {
                selections = [{ id: 'ryan', start: 6, end: 7 }];
                cur('ryan').pos = 7;
                render();
            });
            (function() {
                for (var p = 8; p <= 14; p++) {
                    (function(pos) {
                        after(60, function() {
                            selections[0].end = pos;
                            cur('ryan').pos = pos;
                            render();
                        });
                    })(p);
                }
            })();

            // === Phase 9: Ryan bolds "politics" — highlight flash ===
            after(400, function() {
                bolds = [{ start: 6, end: 14 }];
                selections = [];
                boldHighlight = true;
                render();
            });

            // === Phase 10: Highlight fades (CSS animation), then clean render ===
            after(1400, function() {
                boldHighlight = false;
                render();
            });

            // === Phase 11: All cursors fade out ===
            after(700, function() {
                fading = ['ryan', 'nate', 'galen'];
                render();
            });

            // === Phase 12: Cursors gone — final state ===
            after(600, function() {
                cursors = [];
                fading = [];
                render();
            });

            // === Run ===
            function startCollabAnimation() {
                setTimeout(function() {
                    for (var i = 0; i < timeline.length; i++) {
                        (function(step) {
                            setTimeout(step.fn, step.t);
                        })(timeline[i]);
                    }
                }, 800);
            }

            var loaderEl = document.getElementById('loader');
            if (loaderEl && loaderEl.classList.contains('hidden')) {
                startCollabAnimation();
            } else {
                document.addEventListener('loaderDone', startCollabAnimation, { once: true });
            }
        })();

        // 2. Hero shrink on scroll — removed (normal scroll)

        // 3. Manifold user ID (used by forecasting page chart)
        const MANIFOLD_USER_ID = 'rqyVlY3yvaZkXJ51lMa60NlqbOI3';

        // 4. Scroll-triggered reveal animations
        (function initScrollReveal() {
            const reveals = document.querySelectorAll('.scroll-reveal');
            if (!reveals.length) return;

            // Set initial state
            reveals.forEach((el, i) => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(20px)';
                el.style.transition = `opacity 0.6s ease ${i * 0.15}s, transform 0.6s ease ${i * 0.15}s`;
            });

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            reveals.forEach(el => observer.observe(el));
        })();

        // 4. Fivey bounce counter
        window.fiveyBounceCount = 0;
        window.fiveyMaxSpeed = 0;


        // RESIZABLE BENTO CARDS
        document.querySelectorAll('.bento .card').forEach(card => {
            const handle = document.createElement('div');
            handle.className = 'card-resize-handle';
            card.appendChild(handle);

            let isResizing = false;
            let startX, startY, startW, startH;

            handle.addEventListener('mousedown', e => {
                e.preventDefault();
                e.stopPropagation();
                isResizing = true;
                startX = e.clientX;
                startY = e.clientY;
                startW = card.offsetWidth;
                startH = card.offsetHeight;
                card.classList.add('resizing');
                card.style.width = startW + 'px';
                card.style.height = startH + 'px';

                function onMove(ev) {
                    if (!isResizing) return;
                    const w = Math.max(120, startW + (ev.clientX - startX));
                    const h = Math.max(100, startH + (ev.clientY - startY));
                    card.style.width = w + 'px';
                    card.style.height = h + 'px';
                }

                function onUp() {
                    isResizing = false;
                    card.classList.remove('resizing');
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                }

                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
            });

            // Touch support
            handle.addEventListener('touchstart', e => {
                e.stopPropagation();
                const touch = e.touches[0];
                isResizing = true;
                startX = touch.clientX;
                startY = touch.clientY;
                startW = card.offsetWidth;
                startH = card.offsetHeight;
                card.classList.add('resizing');
                card.style.width = startW + 'px';
                card.style.height = startH + 'px';

                function onTouchMove(ev) {
                    if (!isResizing) return;
                    const t = ev.touches[0];
                    const w = Math.max(120, startW + (t.clientX - startX));
                    const h = Math.max(100, startH + (t.clientY - startY));
                    card.style.width = w + 'px';
                    card.style.height = h + 'px';
                }

                function onTouchEnd() {
                    isResizing = false;
                    card.classList.remove('resizing');
                    document.removeEventListener('touchmove', onTouchMove);
                    document.removeEventListener('touchend', onTouchEnd);
                }

                document.addEventListener('touchmove', onTouchMove, { passive: false });
                document.addEventListener('touchend', onTouchEnd);
            }, { passive: false });
        });

        // FIVEY FOX DRAG WITH PHYSICS
        const mascot = document.querySelector('.mascot-corner');
        const mascotImg = document.querySelector('.mascot-img');
        let isDragging = false;
        let offsetX, offsetY;

        // Physics variables
        let velocityX = 0;
        let velocityY = 0;
        let lastX = 0;
        let lastY = 0;
        let lastTime = 0;
        let animationId = null;

        // Particle trail system
        const particles = [];
        const particleCanvas = document.createElement('canvas');
        particleCanvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:899;';
        document.body.appendChild(particleCanvas);
        const pCtx = particleCanvas.getContext('2d');
        function resizeParticleCanvas() {
            particleCanvas.width = window.innerWidth;
            particleCanvas.height = window.innerHeight;
        }
        resizeParticleCanvas();
        window.addEventListener('resize', resizeParticleCanvas);

        function spawnParticles(x, y, vx, vy, count, type) {
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 3 + 1;
                particles.push({
                    x: x + Math.random() * 20 - 10,
                    y: y + Math.random() * 20 - 10,
                    vx: (type === 'trail' ? -vx * 0.2 : Math.cos(angle) * speed * 3) + (Math.random() - 0.5) * 2,
                    vy: (type === 'trail' ? -vy * 0.2 : Math.sin(angle) * speed * 3) + (Math.random() - 0.5) * 2,
                    life: 1,
                    decay: type === 'bounce' ? 0.015 + Math.random() * 0.01 : 0.025 + Math.random() * 0.02,
                    size: type === 'bounce' ? Math.random() * 5 + 3 : Math.random() * 3 + 1,
                    type: type,
                    shape: Math.random() > 0.5 ? 'star' : 'circle'
                });
            }
        }

        function drawStar(ctx, cx, cy, size) {
            ctx.beginPath();
            for (let i = 0; i < 5; i++) {
                const angle = (i * 4 * Math.PI) / 5 - Math.PI / 2;
                const method = i === 0 ? 'moveTo' : 'lineTo';
                ctx[method](cx + Math.cos(angle) * size, cy + Math.sin(angle) * size);
            }
            ctx.closePath();
            ctx.fill();
        }

        let particleAnimating = false;
        function animateParticles() {
            pCtx.clearRect(0, 0, particleCanvas.width, particleCanvas.height);
            for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                p.x += p.vx;
                p.y += p.vy;
                p.vy += 0.1; // particle gravity
                p.vx *= 0.98;
                p.life -= p.decay;
                if (p.life <= 0) { particles.splice(i, 1); continue; }

                const alpha = p.life * 0.8;
                if (p.type === 'bounce') {
                    pCtx.fillStyle = `rgba(34, 68, 204, ${alpha})`;
                } else {
                    pCtx.fillStyle = `rgba(34, 68, 204, ${alpha * 0.6})`;
                }

                if (p.shape === 'star') {
                    drawStar(pCtx, p.x, p.y, p.size * p.life);
                } else {
                    pCtx.beginPath();
                    pCtx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                    pCtx.fill();
                }
            }

            if (particles.length > 0) {
                requestAnimationFrame(animateParticles);
            } else {
                particleAnimating = false;
            }
        }

        function ensureParticleLoop() {
            if (!particleAnimating) {
                particleAnimating = true;
                animateParticles();
            }
        }

        // Screen shake on hard bounces
        function screenShake(intensity) {
            const shakeAmount = Math.min(intensity * 0.4, 8);
            if (shakeAmount < 1.5) return;
            const duration = Math.min(intensity * 8, 300);
            document.body.style.transition = 'none';
            let start = null;
            function shake(time) {
                if (!start) start = time;
                const elapsed = time - start;
                if (elapsed > duration) {
                    document.body.style.transform = '';
                    return;
                }
                const decay = 1 - elapsed / duration;
                const dx = (Math.random() - 0.5) * shakeAmount * decay;
                const dy = (Math.random() - 0.5) * shakeAmount * decay;
                document.body.style.transform = `translate(${dx}px, ${dy}px)`;
                requestAnimationFrame(shake);
            }
            requestAnimationFrame(shake);
        }

        // Check if Fivey has been moved before
        const savedPosition = localStorage.getItem('fiveyPosition');
        const fiveyHasAppeared = sessionStorage.getItem('fiveyAppeared');
        if (savedPosition) {
            const pos = JSON.parse(savedPosition);
            mascot.classList.add('peeled');
            mascot.style.position = 'fixed';
            mascot.style.left = pos.x + 'px';
            mascot.style.top = pos.y + 'px';
            mascot.style.margin = '0';
            mascot.style.opacity = '1';
            mascot.style.transform = 'none';
            mascot.style.animation = 'none';
        } else if (fiveyHasAppeared) {
            mascot.classList.add('instant');
        }
        mascot.addEventListener('animationend', () => {
            sessionStorage.setItem('fiveyAppeared', 'true');
        });

        // Fade Fivey out as user scrolls down
        window.addEventListener('scroll', () => {
            if (isDragging) return;
            const scrollY = window.scrollY;
            const fadeStart = 80;
            const fadeEnd = 400;
            if (scrollY <= fadeStart) {
                mascot.style.opacity = '1';
                mascot.style.pointerEvents = '';
            } else if (scrollY >= fadeEnd) {
                mascot.style.opacity = '0';
                mascot.style.pointerEvents = 'none';
            } else {
                const pct = 1 - (scrollY - fadeStart) / (fadeEnd - fadeStart);
                mascot.style.opacity = pct;
                mascot.style.pointerEvents = pct < 0.3 ? 'none' : '';
            }
        }, { passive: true });

        function handleDragStart(clientX, clientY, target) {
            if (target.tagName === 'A') return false;

            if (animationId) {
                cancelAnimationFrame(animationId);
                animationId = null;
            }

            isDragging = true;
            mascot.classList.add('dragging', 'peeled');

            const rect = mascot.getBoundingClientRect();
            offsetX = clientX - rect.left;
            offsetY = clientY - rect.top;

            lastX = clientX - offsetX;
            lastY = clientY - offsetY;
            lastTime = Date.now();

            mascot.style.position = 'fixed';
            mascot.style.left = rect.left + 'px';
            mascot.style.top = rect.top + 'px';
            mascot.style.margin = '0';
            mascot.style.right = 'auto';
            mascot.style.bottom = 'auto';

            return true;
        }

        mascotImg.addEventListener('mousedown', (e) => {
            if (handleDragStart(e.clientX, e.clientY, e.target)) {
                e.preventDefault();
                e.stopPropagation();
            }
        });

        mascotImg.addEventListener('touchstart', (e) => {
            if (e.touches.length > 0) {
                if (handleDragStart(e.touches[0].clientX, e.touches[0].clientY, e.target)) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            }
        }, { passive: false });

        function handleDragMove(clientX, clientY) {
            if (!isDragging) return;

            const newX = clientX - offsetX;
            const newY = clientY - offsetY;
            const currentTime = Date.now();
            const deltaTime = currentTime - lastTime;

            if (deltaTime > 0) {
                // Smoothed velocity — gentle throw momentum
                const newVX = (newX - lastX) / deltaTime * 5;
                const newVY = (newY - lastY) / deltaTime * 5;
                velocityX = velocityX * 0.5 + newVX * 0.5;
                velocityY = velocityY * 0.5 + newVY * 0.5;
            }

            lastX = newX;
            lastY = newY;
            lastTime = currentTime;

            mascot.style.left = newX + 'px';
            mascot.style.top = newY + 'px';

            // Keep sticker flat while dragging
            mascotImg.style.transform = `scale(1.15) rotate(-2deg)`;

            localStorage.setItem('fiveyPosition', JSON.stringify({ x: newX, y: newY }));
        }

        function handleDragEnd() {
            if (!isDragging) return;
            isDragging = false;
            mascot.classList.remove('dragging');

            animatePhysics();
        }

        document.addEventListener('mousemove', (e) => {
            handleDragMove(e.clientX, e.clientY);
        });

        document.addEventListener('mouseup', () => {
            handleDragEnd();
        });

        document.addEventListener('touchmove', (e) => {
            if (isDragging && e.touches.length > 0) {
                e.preventDefault();
                handleDragMove(e.touches[0].clientX, e.touches[0].clientY);
            }
        }, { passive: false });

        document.addEventListener('touchend', () => {
            handleDragEnd();
        });

        function animatePhysics() {
            const friction = 0.93;        // More friction — slows down faster
            const bounceFactor = 0.4;     // Less energy retained on bounce
            const minVelocity = 0.3;      // Stop threshold
            let frameCount = 0;

            function animate() {
                let x = parseFloat(mascot.style.left);
                let y = parseFloat(mascot.style.top);

                // No gravity — sticker slides flat like on a desk

                // Apply velocity
                x += velocityX;
                y += velocityY;

                // Apply friction
                velocityX *= friction;
                velocityY *= friction;

                const speed = Math.sqrt(velocityX * velocityX + velocityY * velocityY);

                // Sticker stays flat — no warping, no spin
                mascotImg.style.transform = 'rotate(-2deg)';

                // Get mascot dimensions
                const rect = mascot.getBoundingClientRect();
                const width = rect.width;
                const height = rect.height;

                // Bounce off edges with particles and screen shake
                let bounced = false;
                if (x < 0) {
                    x = 0;
                    const impactSpeed = Math.abs(velocityX);
                    velocityX = Math.abs(velocityX) * bounceFactor;
                    spawnParticles(0, y + height / 2, velocityX, velocityY, Math.min(Math.floor(impactSpeed), 15), 'bounce');
                    screenShake(impactSpeed);
                    bounced = true;
                } else if (x + width > window.innerWidth) {
                    x = window.innerWidth - width;
                    const impactSpeed = Math.abs(velocityX);
                    velocityX = -Math.abs(velocityX) * bounceFactor;
                    spawnParticles(window.innerWidth, y + height / 2, velocityX, velocityY, Math.min(Math.floor(impactSpeed), 15), 'bounce');
                    screenShake(impactSpeed);
                    bounced = true;
                }

                if (y < 0) {
                    y = 0;
                    const impactSpeed = Math.abs(velocityY);
                    velocityY = Math.abs(velocityY) * bounceFactor;
                    spawnParticles(x + width / 2, 0, velocityX, velocityY, Math.min(Math.floor(impactSpeed), 15), 'bounce');
                    screenShake(impactSpeed);
                    bounced = true;
                } else if (y + height > window.innerHeight) {
                    y = window.innerHeight - height;
                    const impactSpeed = Math.abs(velocityY);
                    velocityY = -Math.abs(velocityY) * bounceFactor;
                    spawnParticles(x + width / 2, window.innerHeight, velocityX, velocityY, Math.min(Math.floor(impactSpeed), 15), 'bounce');
                    screenShake(impactSpeed);
                    bounced = true;
                }

                // Update bounce counter
                if (bounced) {
                    ensureParticleLoop();
                    window.fiveyBounceCount++;
                    if (speed > window.fiveyMaxSpeed) window.fiveyMaxSpeed = speed;
                    const counter = document.getElementById('fivey-bounce-counter');
                    if (counter) {
                        counter.style.opacity = '1';
                        counter.textContent = `Bounces: ${window.fiveyBounceCount} | Top speed: ${Math.round(window.fiveyMaxSpeed)}px/f`;
                    }
                }

                // Spawn trail particles when moving fast
                if (speed > 5 && frameCount % 2 === 0) {
                    spawnParticles(x + width / 2, y + height / 2, velocityX, velocityY, 1, 'trail');
                    ensureParticleLoop();
                }

                // Update position
                mascot.style.left = x + 'px';
                mascot.style.top = y + 'px';
                frameCount++;

                // Save position
                localStorage.setItem('fiveyPosition', JSON.stringify({ x, y }));

                // Continue animation if still moving
                if (speed > minVelocity) {
                    animationId = requestAnimationFrame(animate);
                } else {
                    velocityX = 0;
                    velocityY = 0;
                    mascotImg.style.transform = 'rotate(-2deg)';
                    animationId = null;
                }
            }

            const speed = Math.sqrt(velocityX * velocityX + velocityY * velocityY);
            if (speed > minVelocity) {
                animate();
            }
        }

        // Expose physics state for visualization
        window._fivey = {
            get x() { return parseFloat(mascot.style.left) || 0; },
            get y() { return parseFloat(mascot.style.top) || 0; },
            get vx() { return velocityX; },
            get vy() { return velocityY; },
            get dragging() { return isDragging; },
            get animating() { return animationId !== null; },
            mascot: mascot,
            friction: 0.93,
            bounceFactor: 0.4
        };

        // PHYSICS VISUALIZATION MODE
        (function initPhysicsViz() {
            const canvas = document.getElementById('physics-canvas');
            const hud = document.getElementById('physics-hud');
            if (!canvas || !hud) return;
            const ctx = canvas.getContext('2d');
            let active = false;
            let vizAnimId = null;

            function resize() {
                const dpr = window.devicePixelRatio || 1;
                canvas.width = window.innerWidth * dpr;
                canvas.height = window.innerHeight * dpr;
                ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            }

            window.addEventListener('resize', resize);

            function drawArrow(fromX, fromY, toX, toY, color, width) {
                const headLen = 10;
                const dx = toX - fromX;
                const dy = toY - fromY;
                const angle = Math.atan2(dy, dx);
                ctx.strokeStyle = color;
                ctx.lineWidth = width;
                ctx.lineCap = 'round';
                ctx.beginPath();
                ctx.moveTo(fromX, fromY);
                ctx.lineTo(toX, toY);
                ctx.stroke();
                ctx.fillStyle = color;
                ctx.beginPath();
                ctx.moveTo(toX, toY);
                ctx.lineTo(toX - headLen * Math.cos(angle - 0.4), toY - headLen * Math.sin(angle - 0.4));
                ctx.lineTo(toX - headLen * Math.cos(angle + 0.4), toY - headLen * Math.sin(angle + 0.4));
                ctx.closePath();
                ctx.fill();
            }

            function predictTrajectory(startX, startY, vx, vy, steps) {
                const points = [];
                let x = startX, y = startY;
                let svx = vx, svy = vy;
                const f = window._fivey.friction;
                const b = window._fivey.bounceFactor;
                const rect = window._fivey.mascot.getBoundingClientRect();
                const w = rect.width, h = rect.height;
                for (let i = 0; i < steps; i++) {
                    x += svx;
                    y += svy;
                    svx *= f;
                    svy *= f;
                    if (x < 0) { x = 0; svx = Math.abs(svx) * b; }
                    else if (x + w > window.innerWidth) { x = window.innerWidth - w; svx = -Math.abs(svx) * b; }
                    if (y < 0) { y = 0; svy = Math.abs(svy) * b; }
                    else if (y + h > window.innerHeight) { y = window.innerHeight - h; svy = -Math.abs(svy) * b; }
                    points.push({ x: x + w / 2, y: y + h / 2 });
                    if (Math.sqrt(svx * svx + svy * svy) < 0.3) break;
                }
                return points;
            }

            // Trail history -- keeps path visible long after Fivey passes
            const trailHistory = [];
            const maxTrail = 300;
            // Stored vector snapshots so arrows persist
            const vectorHistory = [];
            const maxVectors = 40;
            let frameCount = 0;

            function render() {
                if (!active) return;
                const f = window._fivey;
                const rect = f.mascot.getBoundingClientRect();
                const cx = rect.left + rect.width / 2;
                const cy = rect.top + rect.height / 2;
                const speed = Math.sqrt(f.vx * f.vx + f.vy * f.vy);

                // Record trail
                if (speed > 0.3) {
                    trailHistory.push({ x: cx, y: cy, speed: speed, t: Date.now() });
                    if (trailHistory.length > maxTrail) trailHistory.shift();
                }

                // Record vector snapshots every few frames
                frameCount++;
                if (speed > 0.8 && frameCount % 6 === 0) {
                    vectorHistory.push({ x: cx, y: cy, vx: f.vx, vy: f.vy, t: Date.now() });
                    if (vectorHistory.length > maxVectors) vectorHistory.shift();
                }

                ctx.clearRect(0, 0, canvas.width, canvas.height);

                // Draw persistent trail path
                if (trailHistory.length > 1) {
                    const now = Date.now();
                    for (let i = 1; i < trailHistory.length; i++) {
                        const age = (now - trailHistory[i].t) / 4000; // fade over 4s
                        if (age > 1) continue;
                        const alpha = (1 - age) * 0.7;
                        const hue = Math.min(trailHistory[i].speed * 8, 120);
                        ctx.globalAlpha = alpha;
                        ctx.strokeStyle = `hsl(${hue}, 100%, 60%)`;
                        ctx.lineWidth = 2 + trailHistory[i].speed * 0.15;
                        ctx.beginPath();
                        ctx.moveTo(trailHistory[i - 1].x, trailHistory[i - 1].y);
                        ctx.lineTo(trailHistory[i].x, trailHistory[i].y);
                        ctx.stroke();
                    }
                    ctx.globalAlpha = 1;
                }

                // Draw past vector arrows (ghosted)
                const now2 = Date.now();
                for (const v of vectorHistory) {
                    const age = (now2 - v.t) / 3000;
                    if (age > 1) continue;
                    ctx.globalAlpha = (1 - age) * 0.35;
                    const scale = 8;
                    drawArrow(v.x, v.y, v.x + v.vx * scale, v.y + v.vy * scale, '#ff6b6b', 1.5);
                    ctx.globalAlpha = 1;
                }

                // Current velocity vector (big and bold)
                if (speed > 0.3) {
                    const scale = 10;
                    drawArrow(cx, cy, cx + f.vx * scale, cy + f.vy * scale, '#ff3b3b', 3);

                    // Component vectors
                    if (Math.abs(f.vx) > 0.3) {
                        ctx.globalAlpha = 0.6;
                        drawArrow(cx, cy, cx + f.vx * scale, cy, '#ff8888', 2);
                        ctx.globalAlpha = 1;
                        // Label
                        ctx.font = '13px VT323, monospace';
                        ctx.fillStyle = '#ff8888';
                        ctx.fillText(`vx=${f.vx.toFixed(1)}`, cx + f.vx * scale * 0.5, cy - 10);
                    }
                    if (Math.abs(f.vy) > 0.3) {
                        ctx.globalAlpha = 0.6;
                        drawArrow(cx, cy, cx, cy + f.vy * scale, '#88ff88', 2);
                        ctx.globalAlpha = 1;
                        ctx.font = '13px VT323, monospace';
                        ctx.fillStyle = '#88ff88';
                        ctx.fillText(`vy=${f.vy.toFixed(1)}`, cx + 10, cy + f.vy * scale * 0.5);
                    }

                    // Speed label on main vector
                    ctx.font = '14px VT323, monospace';
                    ctx.fillStyle = '#ff3b3b';
                    const lx = cx + f.vx * scale + 8;
                    const ly = cy + f.vy * scale - 8;
                    ctx.fillText(`${speed.toFixed(1)} px/f`, lx, ly);
                }

                // Trajectory prediction
                if (speed > 0.5) {
                    const trail = predictTrajectory(f.x, f.y, f.vx, f.vy, 300);
                    if (trail.length > 1) {
                        ctx.setLineDash([6, 4]);
                        ctx.lineWidth = 2;
                        for (let i = 1; i < trail.length; i++) {
                            ctx.globalAlpha = 0.5 * (1 - i / trail.length);
                            ctx.strokeStyle = '#00ff88';
                            ctx.beginPath();
                            ctx.moveTo(trail[i - 1].x, trail[i - 1].y);
                            ctx.lineTo(trail[i].x, trail[i].y);
                            ctx.stroke();
                        }
                        ctx.setLineDash([]);
                        ctx.globalAlpha = 1;

                        // Bounce markers along trajectory
                        let px = f.x, py = f.y, pvx = f.vx, pvy = f.vy;
                        const w = rect.width, h = rect.height;
                        for (let i = 0; i < 300; i++) {
                            px += pvx; py += pvy;
                            pvx *= f.friction; pvy *= f.friction;
                            let hit = false;
                            if (px < 0 || px + w > window.innerWidth) hit = true;
                            if (py < 0 || py + h > window.innerHeight) hit = true;
                            if (px < 0) { px = 0; pvx = Math.abs(pvx) * f.bounceFactor; }
                            else if (px + w > window.innerWidth) { px = window.innerWidth - w; pvx = -Math.abs(pvx) * f.bounceFactor; }
                            if (py < 0) { py = 0; pvy = Math.abs(pvy) * f.bounceFactor; }
                            else if (py + h > window.innerHeight) { py = window.innerHeight - h; pvy = -Math.abs(pvy) * f.bounceFactor; }
                            if (hit) {
                                ctx.beginPath();
                                ctx.arc(px + w / 2, py + h / 2, 6, 0, Math.PI * 2);
                                ctx.fillStyle = 'rgba(255, 200, 0, 0.5)';
                                ctx.fill();
                                ctx.strokeStyle = '#ffcc00';
                                ctx.lineWidth = 1.5;
                                ctx.stroke();
                            }
                            if (Math.sqrt(pvx * pvx + pvy * pvy) < 0.3) break;
                        }

                        // Stop point
                        const last = trail[trail.length - 1];
                        ctx.beginPath();
                        ctx.arc(last.x, last.y, 7, 0, Math.PI * 2);
                        ctx.strokeStyle = '#00ff88';
                        ctx.lineWidth = 2;
                        ctx.stroke();
                        ctx.fillStyle = 'rgba(0, 255, 136, 0.25)';
                        ctx.fill();
                        ctx.font = '12px VT323, monospace';
                        ctx.fillStyle = '#00ff88';
                        ctx.fillText('STOP', last.x + 10, last.y + 4);
                    }
                }

                // Position crosshairs
                ctx.strokeStyle = 'rgba(0, 255, 136, 0.12)';
                ctx.lineWidth = 1;
                ctx.setLineDash([2, 4]);
                ctx.beginPath();
                ctx.moveTo(cx, 0); ctx.lineTo(cx, window.innerHeight);
                ctx.moveTo(0, cy); ctx.lineTo(window.innerWidth, cy);
                ctx.stroke();
                ctx.setLineDash([]);

                // Bounding box
                ctx.strokeStyle = 'rgba(255, 59, 59, 0.5)';
                ctx.lineWidth = 1.5;
                ctx.strokeRect(rect.left, rect.top, rect.width, rect.height);

                // Coordinate label at corner
                ctx.font = '12px VT323, monospace';
                ctx.fillStyle = '#00ff88';
                ctx.fillText(`(${Math.round(f.x)}, ${Math.round(f.y)})`, rect.left, rect.top - 6);

                // HUD
                const ke = 0.5 * speed * speed;
                const angle = Math.atan2(f.vy, f.vx) * 180 / Math.PI;
                hud.innerHTML =
                    '<span style="color:#ff3b3b;font-size:16px;">PHYSICS MODE</span><br>' +
                    '------------------------------<br>' +
                    `pos    <span style="color:#fff">(${Math.round(f.x)}, ${Math.round(f.y)})</span><br>` +
                    `vel    <span style="color:#ff8888">vx=${f.vx.toFixed(2)}</span>  <span style="color:#88ff88">vy=${f.vy.toFixed(2)}</span><br>` +
                    `speed  <span style="color:#fff">${speed.toFixed(2)} px/f</span><br>` +
                    `angle  <span style="color:#fff">${speed > 0.3 ? angle.toFixed(1) + 'deg' : '--'}</span><br>` +
                    `KE     <span style="color:#ffcc00">${ke.toFixed(1)}</span> units<br>` +
                    '------------------------------<br>' +
                    `friction    ${f.friction}<br>` +
                    `restitution ${f.bounceFactor}<br>` +
                    `state  ${f.dragging ? '<span style="color:#ffaa00;">DRAGGING</span>' : speed > 0.3 ? '<span style="color:#00ff88;">MOVING</span>' : '<span style="color:#888;">AT REST</span>'}<br>` +
                    `bounces <span style="color:#ffcc00">${window.fiveyBounceCount || 0}</span>  max <span style="color:#ff3b3b">${(window.fiveyMaxSpeed || 0).toFixed(1)}</span> px/f`;

                vizAnimId = requestAnimationFrame(render);
            }

            let continuousId = null;

            window.togglePhysicsViz = function() {
                active = !active;
                canvas.style.display = active ? 'block' : 'none';
                hud.style.display = active ? 'block' : 'none';
                const btn = document.getElementById('physics-toggle-btn');
                if (btn) btn.classList.toggle('active', active);
                if (active) {
                    trailHistory.length = 0;
                    vectorHistory.length = 0;
                    resize();
                    render();
                } else {
                    if (vizAnimId) cancelAnimationFrame(vizAnimId);
                    vizAnimId = null;
                    if (continuousId) clearTimeout(continuousId);
                    continuousId = null;
                }
                return active;
            };
        })();

        // Prevent default drag behavior
        mascotImg.addEventListener('dragstart', (e) => e.preventDefault());

        // TERMINAL MODE
        let terminalDragging = false;
        let terminalOffsetX = 0;
        let terminalOffsetY = 0;

        function openTerminal() {
            const overlay = document.getElementById('terminal-overlay');
            overlay.classList.add('active');
            const input = document.getElementById('terminal-input');
            if (input) {
                setTimeout(() => {
                    input.focus();
                }, 100);
            }
        }

        function closeTerminal() {
            const overlay = document.getElementById('terminal-overlay');
            overlay.classList.remove('active');
        }

        // Terminal background grid
        let terminalCanvas = null;
        let terminalCtx = null;
        let termMouseX = -1000, termMouseY = -1000, termTargetX = -1000, termTargetY = -1000;
        let termPointsState = null;
        const termGridSize = 40, termInfluence = 280, termMaxDisp = 15;

        function resizeTerminalCanvas() {
            if (!terminalCanvas) return;
            terminalCanvas.width = window.innerWidth;
            terminalCanvas.height = window.innerHeight;
            termPointsState = null;
        }

        function initTerminalGrid() {
            terminalCanvas = document.getElementById('terminal-grid');
            const terminalOverlay = document.getElementById('terminal-overlay');

            if (!terminalCanvas || !terminalOverlay) {
                setTimeout(initTerminalGrid, 50);
                return;
            }

            terminalCtx = terminalCanvas.getContext('2d');
            window.addEventListener('resize', resizeTerminalCanvas);
            resizeTerminalCanvas();

            terminalOverlay.addEventListener('mousemove', e => { termTargetX = e.clientX; termTargetY = e.clientY; });
            terminalOverlay.addEventListener('mouseleave', () => { termTargetX = termTargetY = -1000; });
        }

        initTerminalGrid();

        function drawTerminalGrid() {
            if (!terminalCtx || !terminalCanvas) {
                requestAnimationFrame(drawTerminalGrid);
                return;
            }

            termMouseX += (termTargetX - termMouseX) * 0.06;
            termMouseY += (termTargetY - termMouseY) * 0.06;
            terminalCtx.clearRect(0, 0, terminalCanvas.width, terminalCanvas.height);
            terminalCtx.strokeStyle = 'rgba(255, 255, 255, 0.08)';
            terminalCtx.lineWidth = 1;
            const cols = Math.ceil(terminalCanvas.width / termGridSize) + 1;
            const rows = Math.ceil(terminalCanvas.height / termGridSize) + 1;
            if (!termPointsState || termPointsState.length !== rows + 1) {
                termPointsState = [];
                for (let row = 0; row <= rows; row++) {
                    termPointsState[row] = [];
                    for (let col = 0; col <= cols; col++) {
                        termPointsState[row][col] = { x: col * termGridSize, y: row * termGridSize };
                    }
                }
            }
            for (let row = 0; row <= rows; row++) {
                for (let col = 0; col <= cols; col++) {
                    const baseX = col * termGridSize, baseY = row * termGridSize;
                    let targetX = baseX, targetY = baseY;
                    const dx = baseX - termMouseX, dy = baseY - termMouseY;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < termInfluence && dist > 0) {
                        const falloff = 1 - dist / termInfluence;
                        const force = falloff * falloff * falloff * termMaxDisp;
                        const angle = Math.atan2(dy, dx);
                        targetX = baseX + Math.cos(angle) * force;
                        targetY = baseY + Math.sin(angle) * force;
                    }
                    termPointsState[row][col].x += (targetX - termPointsState[row][col].x) * 0.06;
                    termPointsState[row][col].y += (targetY - termPointsState[row][col].y) * 0.06;
                }
            }
            for (let row = 0; row <= rows; row++) {
                terminalCtx.beginPath();
                terminalCtx.moveTo(termPointsState[row][0].x, termPointsState[row][0].y);
                for (let col = 1; col <= cols; col++) {
                    const prev = termPointsState[row][col - 1], curr = termPointsState[row][col];
                    terminalCtx.quadraticCurveTo(prev.x, prev.y, (prev.x + curr.x) / 2, (prev.y + curr.y) / 2);
                }
                terminalCtx.stroke();
            }
            for (let col = 0; col <= cols; col++) {
                terminalCtx.beginPath();
                terminalCtx.moveTo(termPointsState[0][col].x, termPointsState[0][col].y);
                for (let row = 1; row <= rows; row++) {
                    const prev = termPointsState[row - 1][col], curr = termPointsState[row][col];
                    terminalCtx.quadraticCurveTo(prev.x, prev.y, (prev.x + curr.x) / 2, (prev.y + curr.y) / 2);
                }
                terminalCtx.stroke();
            }
            requestAnimationFrame(drawTerminalGrid);
        }
        drawTerminalGrid();

        // Terminal commands
        const commandHistory = [];
        let historyIndex = -1;
        const allCommands = ['/info', '/home', '/exp', '/experience', '/proj', '/projects', '/pics', '/photos', '/contact', '/clear', '/matrix', '/snake', '/dino', '/ascii', '/tetris', '/wordle', '/type', '/desktop', '/sudo', '/quiz', '/2truths', '/weather', '/guestbook', '/resume', '/stats', '/blog', '/physics'];

        const asciiPages = {
